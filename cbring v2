--  SECTION 3 — CORE DRAG ROUTINE
-- ══════════════════════════════════════════════════════════════════════════

-- Main drag-and-fire coroutine
-- Wraps the entire operation in pcall for error safety
local function DragAndFire(victim, attackerRoot, remote)
    local uid  = victim.UserId
    local char = victim.Character
    
    -- Safety checks
    if not char then return end
    if not char.Parent then return end  -- Character might be respawning
    
    local torso    = char:FindFirstChild("Torso")
    local humanoid = char:FindFirstChild("Humanoid")
    
    if not torso or not humanoid or humanoid.Health<=0 then return end
    if not torso.Parent then return end  -- Torso might have been destroyed
    
    if ActiveDrags[uid] then return end
    if tick()-(LastDrag[uid] or 0) < CFG.DragCooldown then return end
    if not IsInFrontArc(attackerRoot, torso) then return end
    
    local realDist = (attackerRoot.Position - torso.Position).Magnitude
    
    ActiveDrags[uid]=true
    LastDrag[uid]=tick()
    Stats.ActiveDrags = Stats.ActiveDrags+1
    
    -- Wrap entire coroutine in pcall for error handling
    coroutine.wrap(function()
        local success, err = pcall(function()
            local dest = attackerRoot.CFrame * CFrame.new(1.2, 0, -2.8)
            
            -- Suppress movement signals on victim's torso
            SuppressSignal(torso.Changed)
            SuppressSignal(torso:GetPropertyChangedSignal("CFrame"))
            
            -- Initial velocity toward destination
            local lp = dest.Position - torso.Position
            torso.AssemblyLinearVelocity = lp.Unit * math.clamp(lp.Magnitude/(CFG.LerpFrames/60),0,55)
            
            local origin = torso.CFrame
            
            -- Smooth lerp over multiple frames
            for i = 1, CFG.LerpFrames do
                -- Re-check parent existence each frame (character might be destroyed)
                if not torso.Parent or not torso.Parent.Parent then
                    break
                end
                
                torso.CFrame = origin:Lerp(dest, (i/CFG.LerpFrames)^2)
                RunService.Heartbeat:Wait()
            end
            
            -- Restore signals
            RestoreSignal(torso.Changed)
            RestoreSignal(torso:GetPropertyChangedSignal("CFrame"))
            
            -- Fire the remote if provided
            if remote then
                pcall(function() remote:FireServer(victim) end)
            end
            
            -- Update stats
            Stats.Kills      = Stats.Kills+1
            Stats.TotalDist  = Stats.TotalDist+realDist
            Stats.LastVictim = victim.Name
            
        end)
        
        -- Cleanup regardless of success/failure
        Stats.ActiveDrags = math.max(0, Stats.ActiveDrags-1)
        ActiveDrags[uid] = nil
        
        -- Log errors if any
        if not success then
            warn("[NoCBring] Drag error:", err)
        end
    end)()
end

