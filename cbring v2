--[[
    IsTeammate — V5-2: reads PlayerTeamCache (zero property reads).
    Two nil-team players are NOT considered teammates (FFA scenario).
    Returns true → skip this player.
--]]
local function IsTeammate(player)
    if not CFG.IgnoreTeam then return false end
    if cachedLocalTeam == nil then return false end
    return PlayerTeamCache[player.UserId] == cachedLocalTeam
end

--[[
    IsTargetTeam — V8: returns true (allow) when TargetTeam is unset or
    when the player is on the configured team.  Returns false (skip) when
    a team is configured and the player is on a different (or no) team.
--]]
local function IsTargetTeam(player)
    if not CFG.TargetTeam or CFG.TargetTeam == "" then return true end
    local team = PlayerTeamCache[player.UserId]
    return team ~= nil and team.Name == CFG.TargetTeam
end

--[[
    IsAlive — V8: uses HumanoidCache.  Returns false (skip) when
    CFG.IgnoreDead is true and the humanoid is dead or not found.
--]]
local function IsAlive(uid)
    if not CFG.IgnoreDead then return true end
    local hum = HumanoidCache[uid]
    if not hum then return false end
    if hum.Health <= 0 then return false end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    return true
end

--[[
    IsVisible — V8: uses the cached torso Part.
    Returns false (skip) when CFG.IgnoreInvisible is true and the
    torso's Transparency is ≥ 1 (fully invisible character).
--]]
local function IsVisible(torso)
    if not CFG.IgnoreInvisible then return true end
    return torso.Transparency < 1
end

--[[
    IsWithinHealthCap — V8: uses HumanoidCache.
    Returns false (skip) when Health > MaxTargetHealth.
    CFG.MaxTargetHealth = 0 disables the check entirely.
--]]
local function IsWithinHealthCap(uid)
    if CFG.MaxTargetHealth <= 0 then return true end
    local hum = HumanoidCache[uid]
    if not hum then return false end
    return hum.Health <= CFG.MaxTargetHealth
end

local function IsWhitelisted(player)
    return Whitelist[player.UserId] == true
end

--[[
    IsInFrontArc — one sqrt, one dot product, one compare.
    arcCF is a composite CFrame: position = handle.Position (sword origin),
    rotation = HumanoidRootPart.CFrame (player facing).
    Built once per Heartbeat; shared by this check and the visualiser.
    Uses cached cosAngleCap — no acos, no degrees conversion.
--]]
local function IsInFrontArc(arcCF, torso)
    local dx = torso.Position.X - arcCF.Position.X
    local dy = torso.Position.Y - arcCF.Position.Y
    local dz = torso.Position.Z - arcCF.Position.Z
    local mag = math.sqrt(dx*dx + dy*dy + dz*dz)
    if mag < 0.1 then return false end
    local lv = arcCF.LookVector
    return (lv.X*dx + lv.Y*dy + lv.Z*dz) / mag >= cosAngleCap
end

local function FindRemote(tool)
