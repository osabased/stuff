-- ═══════════════════════════════════════════════════════════════
--  SECTION 3 — CORE DRAG ROUTINE
-- ═══════════════════════════════════════════════════════════════
--[[
    V5-1: "finally" pattern — cleanup() runs after pcall unconditionally,
    ensuring RestoreSignal fires even if the lerp loop errors mid-drag.
    V5-6: task.spawn routes post-yield errors to the task scheduler.
--]]
local function DragAndFire(victim, attackerRoot, remote, arcCF)
    local uid  = victim.UserId
    local char = victim.Character; if not char then return end
    -- V5-8 / V8: cache lookup first, then fall back to FindFirstChild
    local torso    = TorsoCache[uid]    or FindTorso(char)
    local humanoid = HumanoidCache[uid] or char:FindFirstChildOfClass("Humanoid")
    if not torso or not humanoid then return end

    -- Safety guards (also enforced upstream in the Heartbeat filter chain)
    if humanoid.Health <= 0 then return end
    if humanoid:GetState() == Enum.HumanoidStateType.Dead then return end

    if ActiveDrags[uid] then return end
    if tick()-(LastDrag[uid] or 0) < CFG.DragCooldown then return end
    if not IsInFrontArc(arcCF, torso) then return end

    local realDist = (arcCF.Position - torso.Position).Magnitude
    ActiveDrags[uid]=true; LastDrag[uid]=tick(); Stats.ActiveDrags=Stats.ActiveDrags+1

    task.spawn(function()
        local suppressed = false

        local function cleanup()
            if suppressed then
                RestoreSignal(torso.Changed)
                RestoreSignal(torso:GetPropertyChangedSignal("CFrame"))
                suppressed = false
            end
        end

        local ok, err = pcall(function()
            local dest = attackerRoot.CFrame * CFrame.new(1.2, 0, -2.8)
            SuppressSignal(torso.Changed)
            SuppressSignal(torso:GetPropertyChangedSignal("CFrame"))
            suppressed = true

            local lp = dest.Position - torso.Position
            -- V5-4: guard against zero-vector (attacker and victim at the same point)
            if lp.Magnitude > 0.01 then
                torso.AssemblyLinearVelocity = lp.Unit
                    * math.clamp(lp.Magnitude * (60 / CFG.LerpFrames), 0, 55)
            end

            local origin = torso.CFrame
            for i = 1, CFG.LerpFrames do
                torso.CFrame = origin:Lerp(dest, (i/CFG.LerpFrames)^2)
                RunService.Heartbeat:Wait()
            end
        end)

        cleanup()  -- V5-1: unconditional

        if ok then
            if remote then pcall(function() remote:FireServer(victim) end) end
            Stats.Kills=Stats.Kills+1; Stats.TotalDist=Stats.TotalDist+realDist; Stats.LastVictim=victim.Name
        else
            warn("[NCB] drag error: " .. tostring(err))
        end

        Stats.ActiveDrags=math.max(0,Stats.ActiveDrags-1); ActiveDrags[uid]=nil
    end)
end

-- ═══════════════════════════════════════════════════════════════
--  SECTION 4 — HEARTBEAT
-- ═══════════════════════════════════════════════════════════════
Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    frameCount=frameCount+1
    if frameCount % STATS_THROTTLE == 0 and refreshStats then refreshStats() end
    if CFG.ScriptKilled then return end

    local char=LocalPlayer.Character; if not char then return end
    local tool=char:FindFirstChildOfClass("Tool")
    local root=char:FindFirstChild("HumanoidRootPart")
    if not tool or not root then currentRemote=nil; DestroyArcVis(); return end
    local handle=tool:FindFirstChild("Handle")
    if not handle then DestroyArcVis(); return end
    if not currentRemote then currentRemote=FindRemote(tool) end

    --[[
        arcCF: composite CFrame built once per frame.
          Position = handle.Position  (sword origin — where hits land)
          Rotation = root.CFrame      (player facing — not tool mesh axis)
        IsInFrontArc and UpdateArcVis share this value so the visual cone
        is pixel-accurate with the effective hit zone.
    --]]
    local arcCF = root.CFrame + (handle.Position - root.Position)

    local triggerHeld    = IsTriggerActive()
    local targetsInRange = 0
    local wlInRange      = 0

    -- Localize hot-path values to avoid repeated upvalue lookups
    local hx,hy,hz = handle.Position.X, handle.Position.Y, handle.Position.Z
    local _sizeSq   = sizeSq
    local cache     = PlayerCache

    -- V5-7: increment monotonic frame id; prevFrameId is last frame's id
    wlFrameId = wlFrameId + 1
    local prevFrameId = wlFrameId - 1

    for idx = 1, #cache do
        local player = cache[idx]
        local pc     = player.Character; if not pc then continue end
        local uid    = player.UserId

        -- V5-8: torso from cache (single table lookup, no FindFirstChild)
        local pt = TorsoCache[uid]; if not pt then continue end

        -- Squared distance check — no sqrt
        local dx=hx-pt.Position.X; local dy=hy-pt.Position.Y; local dz=hz-pt.Position.Z
        if dx*dx+dy*dy+dz*dz > _sizeSq then continue end

        -- ── FILTER CHAIN ────────────────────────────────────
        -- V5-2: own-team check via cache — zero property reads
        if IsTeammate(player) then continue end

        -- V8: target-team filter — skip anyone NOT on the chosen team
        if not IsTargetTeam(player) then continue end

        -- V8: skip dead bodies
        if not IsAlive(uid) then continue end

        -- V8: skip invisible characters
        if not IsVisible(pt) then continue end

        -- V8: skip over-health characters
        if not IsWithinHealthCap(uid) then continue end
        -- ────────────────────────────────────────────────────

        if IsWhitelisted(player) then
            wlInRange = wlInRange + 1
            -- V5-7: detect 0→1 transition via frame counter (zero allocs)
            if WLInRangePrev[uid] ~= prevFrameId then
                Stats.WhitelistHits = Stats.WhitelistHits + 1
            end
            WLInRangePrev[uid] = wlFrameId
            continue
        end

        targetsInRange = targetsInRange + 1
        if CFG.Enabled and triggerHeld then
            DragAndFire(player, root, currentRemote, arcCF)
        end
    end

    -- State color (drives the arc cone colour)
    local col
    if not CFG.Enabled           then col=COLOR.DISABLED
    elseif Stats.ActiveDrags > 0 then col=COLOR.FIRING
    elseif targetsInRange > 0    then col=COLOR.TARGET
    elseif wlInRange > 0         then col=COLOR.WHITELIST
    else                              col=COLOR.CLEAR
    end

    UpdateArcVis(arcCF, col)
end)

