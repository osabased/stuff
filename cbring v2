    VisPart.CFrame = handle.CFrame

    -- V4-7: color dirty flag
    if col ~= lastSphereColor and VisSphere then
        VisSphere.Color3        = col
        VisSphere.SurfaceColor3 = col
        lastSphereColor         = col
    end
end

