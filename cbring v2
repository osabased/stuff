--[[
    SuppressSignal(signal: RBXScriptSignal)
    Disables all connections to a signal using getconnections()
    Wrapped in pcall to prevent errors if signal is invalid
    Used to prevent torso physics from interfering with drag
--]]
local function SuppressSignal(sig)
    if not sig then return end
    for _, c in ipairs(getconnections(sig)) do 
        pcall(function() c:Disable() end) 
    end
end

--[[
    RestoreSignal(signal: RBXScriptSignal)
    Re-enables all connections to a signal
    Wrapped in pcall for safety
    Called after drag completes to restore normal physics
--]]
local function RestoreSignal(sig)
    if not sig then return end
    for _, c in ipairs(getconnections(sig)) do 
        pcall(function() c:Enable() end) 
    end
end

--[[
    IsInFrontArc(attackerRoot: Part, victimTorso: Part) → boolean
    Checks if victim is within CFG.AngleCap degrees of attacker's facing direction
    Uses dot product to calculate angle between LookVector and victim direction
    Returns false if victim is too close (<0.1 studs) to avoid division errors
--]]
local function IsInFrontArc(attackerRoot, victimTorso)
    local d = victimTorso.Position - attackerRoot.Position
    if d.Magnitude < 0.1 then return false end
    local dot = attackerRoot.CFrame.LookVector:Dot(d.Unit)
    local angle = math.deg(math.acos(math.clamp(dot, -1, 1)))
    return angle <= CFG.AngleCap
end

--[[
    FindRemote(tool: Tool) → RemoteEvent | RemoteFunction | nil
    Searches for the configured remote in two locations:
    1. Tool descendants (deep search)
    2. ReplicatedStorage descendants (deep search)
    Returns first match that is RemoteEvent or RemoteFunction
    Invalidates cache (currentRemote = nil) if not found
--]]
local function FindRemote(tool)
    local r = tool:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then 
        return r 
    end
    r = ReplicatedStorage:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then 
        return r 
    end
    return nil
end

--[[
    CanDragVictim(victim: Player) → boolean
    Applies all configured filters to determine if victim can be dragged
    Checks:
    - Team filter (if CFG.Filters.IgnoreTeam)
    - Friend filter (if CFG.Filters.IgnoreFriends)
    - Whitelist (if not empty)
    - Blacklist
    Returns true only if all filters pass
--]]
local function CanDragVictim(victim)
    -- Team filter
    if CFG.Filters.IgnoreTeam and LocalPlayer.Team and victim.Team then
        if LocalPlayer.Team == victim.Team then
            return false
        end
    end
    
    -- Friend filter (requires Roblox friend API)
    if CFG.Filters.IgnoreFriends then
        local success, isFriend = pcall(function()
            return Players:GetFriendsAsync(LocalPlayer.UserId):IsFriendsWith(victim.UserId)
        end)
        if success and isFriend then
            return false
        end
    end
    
    -- Whitelist (if configured, only allow these players)
    if #CFG.Filters.Whitelist > 0 then
        local allowed = false
        for _, uid in ipairs(CFG.Filters.Whitelist) do
            if uid == victim.UserId then
                allowed = true
                break
            end
        end
        if not allowed then return false end
    end
    
    -- Blacklist (never allow these players)
    for _, uid in ipairs(CFG.Filters.Blacklist) do
        if uid == victim.UserId then
            return false
        end
    end
    
    return true
end

