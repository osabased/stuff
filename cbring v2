-- SECTION 5 — INPUT / KEYBINDS
-- ============================================================================

--[[
    InputBegan handler handles:
    1. Trigger rebind mode (runs BEFORE GPE check)
    2. Script control keybinds (runs AFTER GPE check)
    
    REBIND FLOW:
    - Click REBIND button → listeningForTrigger = true
    - Next InputBegan (any key/mouse) captured here
    - 0.10s cooldown prevents REBIND click from being captured
    - Escape cancels, any other valid input confirms
    - Updates CFG.TriggerInput and GUI chip label
    
    KEYBINDS (GPE-gated):
    Z: Toggle enabled
    X: Toggle visualizers
    C: Toggle UI
    P: Kill script
--]]
Connections.Input = UIS.InputBegan:Connect(function(input, gpe)
    -- ============================================================================
    -- REBIND INTERCEPT (BEFORE GPE CHECK)
    -- Why before? After clicking REBIND (GPE=true), the NEXT input is what we
    -- want to capture. If that next input is also from GUI, it would normally
    -- be skipped. We must catch it here before the GPE return.
    -- ============================================================================
    if listeningForTrigger then
        -- Cooldown: prevent REBIND button click from being captured
        if tick()-rebindStartTick < 0.10 then 
            return 
        end
        
        -- Escape cancels rebind
        if input.KeyCode == Enum.KeyCode.Escape then
            listeningForTrigger = false
            if triggerBindLabel then
                triggerBindLabel.Text       = CFG.TriggerInput.Name
                triggerBindLabel.TextColor3 = Color3.fromRGB(0, 200, 115)
            end
            
            local ui = getgenv()._NCBRebindUI
            if ui then
                ui.rbLbl.TextColor3 = Color3.fromRGB(105, 105, 128)
                ui.rbStroke.Color   = Color3.fromRGB(38, 38, 52)
                ui.chipStroke.Color = Color3.fromRGB(0, 200, 115)
            end
            
            Notify("Rebind cancelled.")
            return
        end
        
        -- Build new TriggerInput record
        local newTrigger
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            newTrigger = { 
                Kind="Mouse", 
                Button=Enum.UserInputType.MouseButton1, 
                Name="M1" 
            }
        elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
            newTrigger = { 
                Kind="Mouse", 
                Button=Enum.UserInputType.MouseButton2, 
                Name="M2" 
            }
        elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
            newTrigger = { 
                Kind="Mouse", 
                Button=Enum.UserInputType.MouseButton3, 
                Name="M3" 
            }
        elseif input.KeyCode ~= Enum.KeyCode.Unknown then
            newTrigger = { 
                Kind="Key", 
                Code=input.KeyCode, 
                Name=InputToName(input) 
            }
        else
            return  -- Unrecognized input (gamepad etc.) - keep listening
        end
        
        -- Apply new trigger
        CFG.TriggerInput    = newTrigger
        listeningForTrigger = false
        
        -- Update GUI chip label
        if triggerBindLabel then
            triggerBindLabel.Text       = newTrigger.Name
            triggerBindLabel.TextColor3 = Color3.fromRGB(0, 200, 115)
        end
        
        -- Restore button visuals
        local ui = getgenv()._NCBRebindUI
        if ui then
            ui.rbLbl.TextColor3 = Color3.fromRGB(105, 105, 128)
            ui.rbStroke.Color   = Color3.fromRGB(38, 38, 52)
            ui.chipStroke.Color = Color3.fromRGB(0, 200, 115)
        end
        
        Notify("Trigger → " .. newTrigger.Name)
        return
    end
    
    -- ============================================================================
    -- STANDARD KEYBINDS (AFTER GPE CHECK)
    -- Skip if input came from GUI (GameProcessedEvent)
    -- ============================================================================
    if gpe then 
        return 
    end
    
    if input.KeyCode == CFG.Keybinds.Toggle then
        CFG.Enabled = not CFG.Enabled
        if toggles.Enabled then 
            toggles.Enabled.SetState(CFG.Enabled) 
        end
        Notify("Enabled: "..tostring(CFG.Enabled))
        
    elseif input.KeyCode == CFG.Keybinds.ToggleVis then
        CFG.VisualizerEnabled = not CFG.VisualizerEnabled
        if toggles.Visualizer then 
            toggles.Visualizer.SetState(CFG.VisualizerEnabled) 
        end
        if not CFG.VisualizerEnabled then 
            DestroySphereVis()
            DestroyArcVis()
        end
        Notify("Visualizer: "..tostring(CFG.VisualizerEnabled))
        
    elseif input.KeyCode == CFG.Keybinds.ToggleUI then
        guiVisible = not guiVisible
        if ScreenGui then
            for _, obj in ipairs(ScreenGui:GetChildren()) do 
                obj.Visible=guiVisible 
            end
        end
        
    elseif input.KeyCode == CFG.Keybinds.Kill then
        CFG.ScriptKilled = true
        
        -- Cleanup visualizers
        DestroySphereVis()
        DestroyArcVis()
        
        -- Cleanup GUI
        if ScreenGui then 
            ScreenGui:Destroy() 
        end
        
        -- Disconnect all events
        for _, c in pairs(Connections) do 
            pcall(function() c:Disconnect() end) 
        end
        
        -- Cleanup character connections
        for _, c in pairs(charConnections) do
            pcall(function() c:Disconnect() end)
        end
        charConnections = {}
        
        Notify("Script killed.")
    end
end)

