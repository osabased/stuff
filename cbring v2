end
RebuildPlayerCache()

local function WirePlayer(p)
    local uid = p.UserId
    PlayerTeamCache[uid] = p.Team
    if PlayerTeamConns[uid] then PlayerTeamConns[uid]:Disconnect() end
    PlayerTeamConns[uid] = p:GetPropertyChangedSignal("Team"):Connect(function()
        PlayerTeamCache[uid] = p.Team
    end)
    WireCharacter(p)
end

Players.PlayerAdded:Connect(function(p)
    if p == LocalPlayer then return end
    WirePlayer(p)
    RebuildPlayerCache()
end)

Players.PlayerRemoving:Connect(function(p)
    local uid = p.UserId
    if PlayerTeamConns[uid] then PlayerTeamConns[uid]:Disconnect(); PlayerTeamConns[uid] = nil end
    PlayerTeamCache[uid] = nil
    TorsoCache[uid]      = nil
    HumanoidCache[uid]   = nil
    ActiveDrags[uid]     = nil
    LastDrag[uid]        = nil
    WLInRangePrev[uid]   = nil
    RebuildPlayerCache()
end)

-- Wire all currently connected players
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then WirePlayer(p) end
end

