-- PERF-2: no sqrt; dot² ≥ cosAngCapSq×magSq; dot<0 fast-reject
local function IsInFrontArc(arcCF, torso)
    local dx    = torso.Position.X - arcCF.Position.X
    local dy    = torso.Position.Y - arcCF.Position.Y
    local dz    = torso.Position.Z - arcCF.Position.Z
    local magSq = dx*dx + dy*dy + dz*dz
    if magSq < 0.01 then return false end
    local lv  = arcCF.LookVector
    local dot = lv.X*dx + lv.Y*dy + lv.Z*dz
    if dot < 0 then return false end
    return dot * dot >= cosAngCapSq * magSq
end

