Connections.Input = UIS.InputBegan:Connect(function(input, gpe)
    if listeningForTrigger then
        if os.clock()-rebindStartTick < 0.10 then return end
        if input.KeyCode==Enum.KeyCode.Escape then
            listeningForTrigger=false
            if triggerBindLabel then triggerBindLabel.Text=CFG.TriggerInput.Name; triggerBindLabel.TextColor3=UI.ACCENT end
            if _rebindUIRef then
                _rebindUIRef.rbLbl.TextColor3=UI.MUTED
                _rebindUIRef.rbStroke.Color=UI.BORDER
                _rebindUIRef.chipStroke.Color=UI.ACCENT
            end
            Notify("Rebind cancelled."); return
        end
        local nt
        if     input.UserInputType==Enum.UserInputType.MouseButton1 then nt={Kind="Mouse",Button=Enum.UserInputType.MouseButton1,Name="M1"}
        elseif input.UserInputType==Enum.UserInputType.MouseButton2 then nt={Kind="Mouse",Button=Enum.UserInputType.MouseButton2,Name="M2"}
        elseif input.UserInputType==Enum.UserInputType.MouseButton3 then nt={Kind="Mouse",Button=Enum.UserInputType.MouseButton3,Name="M3"}
        elseif input.KeyCode~=Enum.KeyCode.Unknown then nt={Kind="Key",Code=input.KeyCode,Name=InputToName(input)}
        else return end

        local conflict = FindKeybindConflict(nt)
        if conflict then
            listeningForTrigger = false
            if triggerBindLabel then
                triggerBindLabel.Text       = "CONFLICT"
                triggerBindLabel.TextColor3 = UI.WARN
                task.delay(1.5, function()
                    -- EDGE-4: _rebindUIRef may be nil if GUI was destroyed
                    if not CFG.ScriptKilled and triggerBindLabel then
                        triggerBindLabel.Text       = CFG.TriggerInput.Name
                        triggerBindLabel.TextColor3 = UI.ACCENT
                    end
                end)
            end
            if _rebindUIRef then
                _rebindUIRef.rbLbl.TextColor3 = UI.WARN
                _rebindUIRef.rbStroke.Color   = UI.WARN
                _rebindUIRef.chipStroke.Color = UI.WARN
                task.delay(1.5, function()
                    if not CFG.ScriptKilled and _rebindUIRef then
                        _rebindUIRef.rbLbl.TextColor3 = UI.MUTED
                        _rebindUIRef.rbStroke.Color   = UI.BORDER
                        _rebindUIRef.chipStroke.Color = UI.ACCENT
                    end
                end)
            end
            Notify("Conflict: already bound to " .. conflict)
            return
        end

        CFG.TriggerInput=nt; listeningForTrigger=false
        if triggerBindLabel then triggerBindLabel.Text=nt.Name; triggerBindLabel.TextColor3=UI.ACCENT end
        if _rebindUIRef then
            _rebindUIRef.rbLbl.TextColor3=UI.MUTED
            _rebindUIRef.rbStroke.Color=UI.BORDER
            _rebindUIRef.chipStroke.Color=UI.ACCENT
        end
        Notify("Trigger → "..nt.Name); return
    end

    if gpe then return end
    if input.KeyCode==CFG.Keybinds.Toggle then
        CFG.Enabled=not CFG.Enabled
        if toggles.Enabled then toggles.Enabled.SetState(CFG.Enabled) end
        Notify("Enabled: "..tostring(CFG.Enabled))
    elseif input.KeyCode==CFG.Keybinds.ToggleVis then
        CFG.VisualizerEnabled=not CFG.VisualizerEnabled
        if toggles.Visualizer then toggles.Visualizer.SetState(CFG.VisualizerEnabled) end
        if not CFG.VisualizerEnabled then DestroyArcVis() end
        Notify("Visualizer: "..tostring(CFG.VisualizerEnabled))
    elseif input.KeyCode==CFG.Keybinds.ToggleUI then
        if ScreenGui then
            CancelGUITweens()   -- REL-3
            ScreenGui:Destroy()
            ScreenGui=nil; winRef=nil; shadowRef=nil
        else
            local ok, err = pcall(BuildGUI)   -- REL-1: keep toggle path protected too
            if not ok then warn(_S.DragPfx .. " GUI rebuild failed: " .. tostring(err)) end
        end
    elseif input.KeyCode==CFG.Keybinds.Kill then
        CFG.ScriptKilled=true
        DestroyArcVis()

        if arcFolderOwned and arcFolder and arcFolder.Parent then
            pcall(arcFolder.Destroy, arcFolder)
        end
        arcFolder=nil; arcFolderOwned=false

        CancelGUITweens()   -- REL-3: cancel tweens before destroying GUI
        if ScreenGui then ScreenGui:Destroy(); ScreenGui=nil end

        -- BUG-3: Connections now includes PlayerAdded, PlayerRemoving,
        --        CharAdded (LocalPlayer), TeamChanged (LocalPlayer)
        for _,c in pairs(Connections)     do pcall(c.Disconnect,c) end
        for _,c in pairs(PlayerTeamConns) do pcall(c.Disconnect,c) end   -- pairs: UserId-keyed
        for _,c in pairs(CharAddedConns)  do pcall(c.Disconnect,c) end   -- pairs: UserId-keyed
        for _,c in ipairs(localCharConns) do pcall(c.Disconnect,c) end   -- ipairs: array

        -- M-3: scrub all sensitive caches
        table.clear(TorsoCache)
        table.clear(HumanoidCache)
        table.clear(PlayerTeamCache)
        table.clear(PlayerCache)
        table.clear(RootCache)       -- PERF-A cache
        table.clear(Whitelist)
        table.clear(ActiveDrags)
        table.clear(LastDrag)
        table.clear(WLInRangePrev)
        _cfgReal.WhitelistURL = ""
        _cfgReal.RemoteName   = ""
        getgenv()[_cfgKey]    = nil
        getgenv()[_guardKey]  = nil

        -- EV-1 + M-3: zero baseline
        _gc_baseline = nil

        Notify("Script killed.")
    end
end)

-- ─────────────────────────────────────────────────────────────
-- CHARACTER WIRING — LOCAL PLAYER
-- BUG-5: localCharConns cleared at start of each respawn
-- PERF-A: RootCache populated here
-- ─────────────────────────────────────────────────────────────
local function OnChar(char)
    if wiredChars[char] then return end

    -- BUG-5: disconnect and clear previous character's connections before wiring new one
    for _, c in ipairs(localCharConns) do pcall(c.Disconnect, c) end
    table.clear(localCharConns)
    wiredChars = {}        -- previous char keys are now stale
    wiredChars[char] = true

    -- PERF-A: cache the HumanoidRootPart
    RootCache[LocalPlayer] = char:FindFirstChild(_S.HRP)

    ToolCache[LocalPlayer] = nil
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA(_S.Tool) then ToolCache[LocalPlayer] = c; break end
    end

    localCharConns[#localCharConns+1] = char.ChildAdded:Connect(function(c)
        if c:IsA(_S.Tool) then
            ToolCache[LocalPlayer] = c
            currentRemote = nil
        end
        -- PERF-A: update RootCache if HRP is added after character load
        if c.Name == _S.HRP then RootCache[LocalPlayer] = c end
    end)
    localCharConns[#localCharConns+1] = char.ChildRemoved:Connect(function(c)
        if c:IsA(_S.Tool) then
            ToolCache[LocalPlayer]   = nil
            currentRemote            = nil
            lastRemoteSearchTime     = -math.huge
            DestroyArcVis()
        end
        if c.Name == _S.HRP then RootCache[LocalPlayer] = nil end
    end)
    localCharConns[#localCharConns+1] = char.AncestryChanged:Connect(function()
        if not char.Parent then
            wiredChars[char]         = nil
            ToolCache[LocalPlayer]   = nil
            RootCache[LocalPlayer]   = nil
        end
    end)
end

-- BUG-3: CharacterAdded stored in Connections for kill-handler teardown
Connections.CharAdded = LocalPlayer.CharacterAdded:Connect(OnChar)
if LocalPlayer.Character then OnChar(LocalPlayer.Character) end

-- BUG-3: Team change stored in Connections
Connections.TeamChanged = LocalPlayer:GetPropertyChangedSignal("Team"):Connect(function()
    cachedLocalTeam = LocalPlayer.Team
end)

