--  SECTION 4 — HEARTBEAT
-- ═══════════════════════════════════════════════════════════════
Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    if CFG.ScriptKilled then return end

    frameCount=frameCount+1
    if frameCount % STATS_THROTTLE == 0 and refreshStats then refreshStats() end

    -- EDGE-11: reset monotonic counter before float precision degrades
    if wlFrameId >= 9e15 then
        wlFrameId   = 1
        WLInRangePrev = {}
    end

    local char=LocalPlayer.Character; if not char then return end
    -- EDGE-10: ToolCache lookup — O(1) instead of O(children) per frame
    local tool=ToolCache[LocalPlayer]
    local root=char:FindFirstChild("HumanoidRootPart")
    if not tool or not root then
        currentRemote=nil
        lastRemoteSearchTime=-math.huge
        DestroyArcVis(); return
    end
    local handle=tool:FindFirstChild("Handle")
    if not handle then DestroyArcVis(); return end
    if not currentRemote then currentRemote=FindRemote(tool) end

    local arcCF = root.CFrame + (handle.Position - root.Position)

    local triggerHeld    = IsTriggerActive()
    local targetsInRange = 0
    local wlInRange      = 0

    local hx,hy,hz  = handle.Position.X, handle.Position.Y, handle.Position.Z
    local _sizeSq   = sizeSq
    local cache     = PlayerCache
    local _humCache = HumanoidCache

    wlFrameId = wlFrameId + 1
    local prevFrameId = wlFrameId - 1

    for idx = 1, #cache do
        local player = cache[idx]
        local pc     = player.Character; if not pc then continue end
        local uid    = player.UserId

        local pt = TorsoCache[uid]; if not pt then continue end

        local dx=hx-pt.Position.X; local dy=hy-pt.Position.Y; local dz=hz-pt.Position.Z
        if dx*dx+dy*dy+dz*dz > _sizeSq then continue end

        -- ── FILTER CHAIN ────────────────────────────────────
        if IsTeammate(player)       then continue end
        if not IsTargetTeam(player) then continue end   -- BUG-1: object compare

        local hum = _humCache[uid]; if not hum then continue end

        if not IsAlive(hum)             then continue end   -- EDGE-2: Health + GetState
        if not IsVisible(pt)            then continue end   -- EDGE-1: CFG.InvisThreshold
        if not IsWithinHealthCap(hum)   then continue end
        -- ────────────────────────────────────────────────────

        if IsWhitelisted(player) then
            wlInRange = wlInRange + 1
            if WLInRangePrev[uid] ~= prevFrameId then
                Stats.WhitelistHits = Stats.WhitelistHits + 1
            end
            WLInRangePrev[uid] = wlFrameId
            continue
        end

        targetsInRange = targetsInRange + 1
        if CFG.Enabled and triggerHeld then
            DragAndFire(player, root, currentRemote, arcCF)
        end
    end

    local col
    if not CFG.Enabled           then col=COLOR.DISABLED
    elseif Stats.ActiveDrags > 0 then col=COLOR.FIRING
    elseif targetsInRange > 0    then col=COLOR.TARGET
    elseif wlInRange > 0         then col=COLOR.WHITELIST
    else                              col=COLOR.CLEAR
    end

    UpdateArcVis(arcCF, col)
end)

