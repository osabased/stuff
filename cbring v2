-- 16 neon Parts anchored in workspace:
--   ArcPool[1]      — left radius line
--   ArcPool[2]      — right radius line
--   ArcPool[3..16]  — 14 arc boundary segments
--
-- Origin: HumanoidRootPart.CFrame
-- This is intentional. IsInFrontArc() uses attackerRoot.CFrame.LookVector,
-- so the arc must originate from HRP to show what the engine is actually
-- checking. The sphere originates from Handle — both are visible, making
-- the offset between handle-position and body-orientation apparent.

local ARC_SEGS = 14  -- Number of segments in the arc boundary
local ArcPool  = {}

-- Position a part along the line from p1 to p2
-- Uses CFrame.lookAt to orient the part, and Size.Z as the long axis
local function SetBeam(part, p1, p2, thick)
    local len = (p2 - p1).Magnitude
    if len < 0.001 then
        part.Size = Vector3.new(.001,.001,.001)
        return
    end
    
    local mid = (p1 + p2) / 2
    local dir = (p2 - p1).Unit
    
    part.Size   = Vector3.new(thick, thick, len)
    part.CFrame = CFrame.lookAt(mid, mid + dir)
end

-- Create or recreate all arc visualizer parts
local function BuildArcVis()
    for _, p in ipairs(ArcPool) do
        pcall(function() p:Destroy() end)
    end
    ArcPool = {}
    
    for i = 1, 2 + ARC_SEGS do
        local p = Instance.new("Part")
        p.Name = "_NCBArc"
        p.Anchored = true
        p.CanCollide = false
        p.CastShadow = false
        p.Massless = true
        p.Material = Enum.Material.Neon
        p.Transparency = 0.15
        p.Size = Vector3.new(.07,.07,1)
        p.Color = COLOR.CLEAR
        p.Parent = workspace
        ArcPool[i] = p
    end
end

-- Destroy all arc visualizer parts
local function DestroyArcVis()
    for _, p in ipairs(ArcPool) do
        pcall(function() p:Destroy() end)
    end
    ArcPool = {}
end

-- Recalculate all arc parts every Heartbeat
-- baseCF: HumanoidRootPart.CFrame (position + facing direction)
-- col:    Color3 matching current state
local function UpdateArcVis(baseCF, col)
    if not CFG.VisualizerEnabled then
        DestroyArcVis()
        return
    end
    
    if #ArcPool == 0 then
        BuildArcVis()
    end
    
    local reach = CFG.Size
    local half  = CFG.AngleCap
    
    -- Helper: Get world position at angle `deg` on the arc boundary
    local function ArcPoint(deg)
        return baseCF.Position
            + (baseCF * CFrame.Angles(0, math.rad(deg), 0)).LookVector * reach
    end
    
    local origin = baseCF.Position
    
    -- Left and right radius lines
    SetBeam(ArcPool[1], origin, ArcPoint(-half), 0.09)
    ArcPool[1].Color = col
    
    SetBeam(ArcPool[2], origin, ArcPoint( half), 0.09)
    ArcPool[2].Color = col
    
    -- Arc boundary segments
    -- Subdivide the full sweep -half → +half into ARC_SEGS equal steps.
    -- Each segment is a beam between consecutive arc points.
    for i = 1, ARC_SEGS do
        local a1   = -half + (2*half / ARC_SEGS) * (i-1)
        local a2   = -half + (2*half / ARC_SEGS) * i
        local part = ArcPool[2 + i]
        
        SetBeam(part, ArcPoint(a1), ArcPoint(a2), 0.07)
        part.Color = col
    end
end

