--[[
    ParseWhitelist — pure function, no side effects.
    Accepts CR+LF and LF line endings.
    Lines starting with # (after trimming) are comments.
    Only positive integers are stored.  Returns (set, count).
--]]
local function ParseWhitelist(raw)
    local set, count = {}, 0
    for line in (raw .. "\n"):gmatch("([^\r\n]*)\r?\n") do
        local t = line:match("^%s*(.-)%s*$")
        if t == "" or t:sub(1,1) == "#" then continue end
        local id = tonumber(t)
        if id and id > 0 and id == math.floor(id) then
            set[id] = true; count = count + 1
        end
    end
    return set, count
end

--[[
    FetchWhitelist — called via task.spawn AFTER BuildGUI (V4-4).
    isFetching guard prevents concurrent runs (V4-3).
    3-attempt exponential back-off (1 s, 2 s, 4 s).
    On success: atomic table swap + WhitelistHits reset (V4-11).
    On failure: status label turns red; warn() logs the full error.
--]]
local function FetchWhitelist()
    if isFetching then return end
    isFetching = true
    local url = CFG.WhitelistURL
    if not url or url == "" then
        WhitelistStatus = "No URL set"
        if wlStatusLabel then wlStatusLabel.Text = WhitelistStatus end
        isFetching = false; return
    end
    WhitelistStatus = "Loading..."
    if wlStatusLabel then wlStatusLabel.Text = WhitelistStatus end
    if wlRefLbl      then wlRefLbl.Text      = "..." end
    local delay, lastErr = 1, "unknown"
    for attempt = 1, WL_MAX_RETRIES do
        if attempt > 1 then task.wait(delay); delay = delay * 2 end
        local ok, result = pcall(function() return game:HttpGet(url, true) end)
        if ok and type(result) == "string" and #result > 0 then
            local set, count = ParseWhitelist(result)
            Whitelist           = set
            WhitelistStatus     = string.format("Loaded %d id%s", count, count==1 and "" or "s")
            Stats.WhitelistHits = 0
            WLInRangePrev       = {}
            if wlStatusLabel then wlStatusLabel.Text = WhitelistStatus; wlStatusLabel.TextColor3 = Color3.fromRGB(0,180,255) end
            if wlRefLbl      then wlRefLbl.Text = "REFRESH" end
            Notify(string.format("Whitelist: %d id%s loaded.", count, count==1 and "" or "s"))
            isFetching = false; return
        else
            lastErr = tostring(result)
        end
    end
    WhitelistStatus = string.format("Failed (%d tries)", WL_MAX_RETRIES)
    if wlStatusLabel then wlStatusLabel.Text = WhitelistStatus; wlStatusLabel.TextColor3 = Color3.fromRGB(255,80,80) end
    if wlRefLbl      then wlRefLbl.Text = "REFRESH" end
    warn("[NCB WL] All retries failed — last error: " .. lastErr)
    isFetching = false
end

