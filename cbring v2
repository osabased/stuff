--  SECTION 4 — HEARTBEAT LOOP
-- ══════════════════════════════════════════════════════════════════════════

Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    -- Update stats display
    if refreshStats then refreshStats() end
    
    -- Early exit if script is killed
    if CFG.ScriptKilled then return end
    
    -- Get local player character and essential parts
    local char = LocalPlayer.Character
    if not char then return end
    
    local tool     = char:FindFirstChildOfClass("Tool")
    local humanoid = char:FindFirstChild("Humanoid")
    local root     = char:FindFirstChild("HumanoidRootPart")
    
    if not tool or not humanoid or not root then
        currentRemote=nil
        DestroySphereVis()
        DestroyArcVis()
        return
    end
    
    local handle = tool:FindFirstChild("Handle")
    if not handle then
        DestroySphereVis()
        DestroyArcVis()
        return
    end
    
    -- Cache remote if not already found
    if not currentRemote then
        currentRemote = FindRemote(tool)
    end
    
    -- Check if trigger is held (using hotswap input system)
    local triggerHeld    = IsTriggerActive()
    local targetsInRange = 0
    
    -- PERFORMANCE OPTIMIZATION: Calculate squared distance threshold once
    local rangeSq = (CFG.Size * 1.5) ^ 2  -- Spatial culling: skip beyond 1.5x range
    
    -- Scan all players for potential targets
    for _, player in ipairs(Players:GetPlayers()) do
        if player==LocalPlayer then continue end
        
        local pc = player.Character
        if not pc then continue end
        
        local pt = pc:FindFirstChild("Torso")
        if not pt then continue end
        
        -- PERFORMANCE OPTIMIZATION: Spatial culling
        -- Skip distance calculation if beyond extended range
        local distSq = (handle.Position - pt.Position).Magnitude ^ 2
        if distSq > rangeSq then continue end
        
        -- Full distance check for actual range
        if math.sqrt(distSq) <= CFG.Size then
            targetsInRange = targetsInRange + 1
            
            -- Only drag if enabled and trigger held
            if CFG.Enabled and triggerHeld then
                DragAndFire(player, root, currentRemote)
            end
        end
    end
    
    -- Determine visualizer color state
    local col
    if not CFG.Enabled then
        col = COLOR.DISABLED
    elseif Stats.ActiveDrags > 0 then
        col = COLOR.FIRING
    elseif targetsInRange > 0 then
        col = COLOR.TARGET
    else
        col = COLOR.CLEAR
    end
    
    -- Update visualizers
    UpdateSphereVis(handle, col)  -- Sphere centered on Handle (reach origin)
    UpdateArcVis(root.CFrame, col)  -- Arc centered on HRP (angle origin)
end)

