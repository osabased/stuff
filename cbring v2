-- ── Target Team autocomplete dropdown ─────────────────────────
--[[
    BuildTeamSelector — v8
    Creates a text box with live autocomplete against Teams:GetTeams().
    Clicking a suggestion sets CFG.TargetTeam to that Team object.
    The × button clears the filter (nil = all teams).
    The dropdown frame is parented to `win` at a high ZIndex so it
    renders above any sibling elements in the content frame.
--]]
local function BuildTeamSelector(content, win, y)
    MkLabel(content, "Target Team", UDim2.new(0,95,0,22), UDim2.new(0,UI.Pad,0,y), UI.FontBody, UI.TextSz, UI.MUTED, 3)

    local selectorBG = MkFrame(content, UDim2.new(0,UI.W-116,0,22), UDim2.new(0,108,0,y+1), Color3.fromRGB(26,26,38), 3)
    MkCorner(selectorBG, 4); MkStroke(selectorBG, UI.BORDER, 1)

    local tBox = Instance.new("TextBox")
    tBox.Size               = UDim2.new(1,-26,1,0); tBox.Position = UDim2.new(0,4,0,0)
    tBox.Text               = CFG.TargetTeam and CFG.TargetTeam.Name or ""
    tBox.Font               = UI.FontBody; tBox.TextSize = UI.TextSz
    tBox.TextColor3         = UI.TEXT
    tBox.BackgroundTransparency = 1; tBox.BorderSizePixel = 0; tBox.ZIndex = 4
    tBox.PlaceholderText    = "All teams"; tBox.PlaceholderColor3 = UI.MUTED
    tBox.ClearTextOnFocus   = false; tBox.Parent = selectorBG

    -- Clear (×) button
    local xBtn = MkFrame(selectorBG, UDim2.new(0,20,1,-4), UDim2.new(1,-22,0,2), Color3.fromRGB(52,17,26), 4)
    MkCorner(xBtn, 3)
    MkLabel(xBtn, "×", UDim2.new(1,0,1,0), UDim2.new(0,0,0,0), UI.Font, 13, UI.ACCENT2, 5, Enum.TextXAlignment.Center)
    xBtn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            CFG.TargetTeam = nil; tBox.Text = ""; Notify("Target Team: All")
        end
    end)

    -- Dropdown frame — parented to win at high ZIndex so it overlays content
    local dropFrame = MkFrame(win, UDim2.new(0,UI.W-116,0,0), UDim2.new(0,116,0,y + UI.TitleH + 24), Color3.fromRGB(22,22,34), 25)
    MkCorner(dropFrame, 4); MkStroke(dropFrame, UI.BORDER, 1)
    dropFrame.ClipsDescendants = true; dropFrame.Visible = false

    local dropLayout = Instance.new("UIListLayout")
    dropLayout.SortOrder   = Enum.SortOrder.LayoutOrder
    dropLayout.FillDirection = Enum.FillDirection.Vertical
    dropLayout.Parent      = dropFrame

    local function HideDropdown()
        dropFrame.Visible = false
        -- Clear children
        for _, c in ipairs(dropFrame:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
    end

    local function PopulateDropdown(filter)
        HideDropdown()
        local allTeams = Teams:GetTeams()
        if #allTeams == 0 then return end
        local lfilter = filter:lower()
        local matches = {}
        for _, t in ipairs(allTeams) do
            if lfilter == "" or t.Name:lower():find(lfilter, 1, true) then
                matches[#matches + 1] = t
            end
        end
        if #matches == 0 then return end

        for i, team in ipairs(matches) do
            local btn = Instance.new("TextButton")
            btn.Size               = UDim2.new(1,0,0,22)
            btn.LayoutOrder        = i
            btn.Text               = "  " .. team.Name
            btn.Font               = UI.FontBody; btn.TextSize = UI.TextSz - 1
            btn.TextColor3         = UI.TEXT
            btn.BackgroundColor3   = Color3.fromRGB(26,26,38)
            btn.BorderSizePixel    = 0; btn.ZIndex = 26
            btn.TextXAlignment     = Enum.TextXAlignment.Left
            btn.MouseEnter:Connect(function()  btn.BackgroundColor3 = Color3.fromRGB(40,40,58) end)
            btn.MouseLeave:Connect(function()  btn.BackgroundColor3 = Color3.fromRGB(26,26,38) end)
            btn.Activated:Connect(function()
                CFG.TargetTeam = team; tBox.Text = team.Name
                HideDropdown(); Notify("Target Team: " .. team.Name)
            end)
            btn.Parent = dropFrame
        end

        local shown = math.min(#matches, 5)
        dropFrame.Size    = UDim2.new(0, UI.W-116, 0, shown * 22)
        dropFrame.Visible = true
    end

    tBox:GetPropertyChangedSignal("Text"):Connect(function()
        if tBox:IsFocused() then PopulateDropdown(tBox.Text) end
    end)
    tBox.Focused:Connect(function() PopulateDropdown(tBox.Text) end)
    tBox.FocusLost:Connect(function(enterPressed)
        task.delay(0.15, HideDropdown)
        if enterPressed then
            local txt = tBox.Text:lower()
            for _, t in ipairs(Teams:GetTeams()) do
                if t.Name:lower() == txt then
                    CFG.TargetTeam = t; tBox.Text = t.Name
                    Notify("Target Team: " .. t.Name); return
                end
            end
            CFG.TargetTeam = nil; tBox.Text = ""
        end
    end)

    -- Keep text box in sync if CFG.TargetTeam is cleared externally
    Teams.TeamAdded:Connect(function()   end)   -- hook for future extension
    Teams.TeamRemoved:Connect(function(removedTeam)
        if CFG.TargetTeam == removedTeam then
            CFG.TargetTeam = nil; tBox.Text = ""; Notify("Target Team cleared (team removed)")
        end
    end)
end

