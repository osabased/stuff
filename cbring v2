--[[
    MkSlider — no UIS global listeners inside (V4-9).
    Sets activeDrag on press; the module-level UIS.InputChanged /
    UIS.InputEnded dispatch to it.
--]]
local function MkSlider(par,y,label,mn,mx,def,fmt,onChange)
    local row=MkFrame(par,UDim2.new(1,0,0,UI.RowH),UDim2.new(0,0,0,y),Color3.fromRGB(0,0,0),2)
    row.BackgroundTransparency=1
    MkLabel(row,label,UDim2.new(0,95,1,0),UDim2.new(0,UI.Pad,0,0),UI.FontBody,UI.TextSz,UI.MUTED,3)
    local track=MkFrame(row,UDim2.new(0,UI.SliderW,0,UI.SliderH),UDim2.new(0,108,0.5,-UI.SliderH/2),Color3.fromRGB(38,38,52),3)
    MkCorner(track,4)
    local fill=MkFrame(track,UDim2.new(0,0,1,0),UDim2.new(0,0,0,0),UI.ACCENT,4); MkCorner(fill,4)
    local KS=UI.KnobSz
    local knob=MkFrame(track,UDim2.new(0,KS,0,KS),UDim2.new(0,-KS/2,0.5,-KS/2),Color3.fromRGB(255,255,255),5)
    MkCorner(knob,KS); MkStroke(knob,UI.ACCENT,2)
    local valLbl=MkLabel(row,fmt(def),UDim2.new(0,58,1,0),UDim2.new(0,108+UI.SliderW+6,0,0),UI.Font,UI.TextSz,UI.ACCENT,3)
    local isInt=math.floor(mn)==mn and math.floor(mx)==mx and math.floor(def)==def

    local function SetVal(v)
        v=math.clamp(v,mn,mx)
        v=isInt and math.round(v) or (math.floor(v*100+0.5)/100)
        local a=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(a,0,1,0); knob.Position=UDim2.new(a,-KS/2,0.5,-KS/2)
        valLbl.Text=fmt(v)
        if onChange then onChange(v) end
    end
    SetVal(def)

    local info={track=track,mn=mn,mx=mx,SetVal=SetVal}
    knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then activeDrag=info end end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            activeDrag=info
            local r=track.AbsoluteSize.X
            SetVal(mn+(math.clamp(i.Position.X-track.AbsolutePosition.X,0,r)/r)*(mx-mn))
        end
    end)
    return {SetVal=SetVal}
end

local function MkToggle(par,xOff,yOff,label,def,onChange)
    local BW,BH=46,22
    local con=MkFrame(par,UDim2.new(0,BW+80,0,BH+4),UDim2.new(0,xOff,0,yOff),Color3.fromRGB(0,0,0),2)
    con.BackgroundTransparency=1
    local track=MkFrame(con,UDim2.new(0,BW,0,BH),UDim2.new(0,0,0,2),Color3.fromRGB(46,46,60),3)
    MkCorner(track,BH); MkStroke(track,UI.BORDER,1)
    local KS=BH-6
    local knob=MkFrame(track,UDim2.new(0,KS,0,KS),UDim2.new(0,3,0.5,-KS/2),Color3.fromRGB(170,170,190),4)
    MkCorner(knob,KS)
    MkLabel(con,label,UDim2.new(0,72,1,0),UDim2.new(0,BW+8,0,0),UI.FontBody,UI.TextSz,UI.TEXT,3)
    local on=def; local twi=TweenInfo.new(0.15,Enum.EasingStyle.Quad)
    local function SetState(st)
        on=st
        TweenService:Create(knob,twi,{Position=UDim2.new(0,st and(BW-KS-3)or 3,0.5,-KS/2),BackgroundColor3=st and Color3.fromRGB(255,255,255)or Color3.fromRGB(170,170,190)}):Play()
        TweenService:Create(track,twi,{BackgroundColor3=st and UI.ACCENT or Color3.fromRGB(46,46,60)}):Play()
        if onChange then onChange(st) end
    end
    SetState(def)
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then SetState(not on) end end)
    return {SetState=SetState,GetState=function() return on end}
end

