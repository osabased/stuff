--  SECTION 5 — INPUT HANDLING & KEYBINDS
-- ══════════════════════════════════════════════════════════════════════════

Connections.Input = UIS.InputBegan:Connect(function(input, gpe)
    -- ── REBIND INTERCEPT ──────────────────────────────────────────────────
    -- Runs BEFORE `if gpe then return end` to capture GUI inputs during rebind
    -- The 0.10 s cooldown prevents the REBIND button click from being captured
    if listeningForTrigger then
        if tick()-rebindStartTick < 0.10 then return end
        
        -- Escape cancels rebind
        if input.KeyCode == Enum.KeyCode.Escape then
            listeningForTrigger = false
            
            if triggerBindLabel then
                triggerBindLabel.Text       = CFG.TriggerInput.Name
                triggerBindLabel.TextColor3 = UI.ACCENT
            end
            
            local ui = getgenv()._NCBRebindUI
            if ui then
                ui.rbLbl.TextColor3 = UI.MUTED
                ui.rbStroke.Color   = UI.BORDER
                ui.chipStroke.Color = UI.ACCENT
            end
            
            Notify("Rebind cancelled.")
            return
        end
        
        -- Build new TriggerInput record based on input type
        local newTrigger
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            newTrigger = { Kind="Mouse", Button=Enum.UserInputType.MouseButton1, Name="M1" }
        elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
            newTrigger = { Kind="Mouse", Button=Enum.UserInputType.MouseButton2, Name="M2" }
        elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
            newTrigger = { Kind="Mouse", Button=Enum.UserInputType.MouseButton3, Name="M3" }
        elseif input.KeyCode ~= Enum.KeyCode.Unknown then
            newTrigger = { Kind="Key", Code=input.KeyCode, Name=InputToName(input) }
        else
            return  -- unrecognized input type (gamepad etc.) — keep listening
        end
        
        -- Apply new trigger
        CFG.TriggerInput    = newTrigger
        listeningForTrigger = false
        
        -- Update chip label
        if triggerBindLabel then
            triggerBindLabel.Text       = newTrigger.Name
            triggerBindLabel.TextColor3 = UI.ACCENT
        end
        
        -- Restore button visuals
        local ui = getgenv()._NCBRebindUI
        if ui then
            ui.rbLbl.TextColor3 = UI.MUTED
            ui.rbStroke.Color   = UI.BORDER
            ui.chipStroke.Color = UI.ACCENT
        end
        
        Notify("Trigger → " .. newTrigger.Name)
        return
    end
    
    -- ── STANDARD KEYBINDS (GPE-gated) ────────────────────────────────────
    if gpe then return end
    
    if input.KeyCode == CFG.Keybinds.Toggle then
        CFG.Enabled = not CFG.Enabled
        if toggles.Enabled then toggles.Enabled.SetState(CFG.Enabled) end
        Notify("Enabled: "..tostring(CFG.Enabled))
        
    elseif input.KeyCode == CFG.Keybinds.ToggleVis then
        CFG.VisualizerEnabled = not CFG.VisualizerEnabled
        if toggles.Visualizer then toggles.Visualizer.SetState(CFG.VisualizerEnabled) end
        if not CFG.VisualizerEnabled then
            DestroySphereVis()
            DestroyArcVis()
        end
        Notify("Visualizer: "..tostring(CFG.VisualizerEnabled))
        
    elseif input.KeyCode == CFG.Keybinds.ToggleUI then
        guiVisible = not guiVisible
        if ScreenGui then
            for _, obj in ipairs(ScreenGui:GetChildren()) do
                obj.Visible = guiVisible
            end
        end
        
    elseif input.KeyCode == CFG.Keybinds.Kill then
        CFG.ScriptKilled = true
        DestroySphereVis()
        DestroyArcVis()
        
        if ScreenGui then ScreenGui:Destroy() end
        
        -- Disconnect all connections
        for _, c in pairs(Connections) do
            pcall(function() c:Disconnect() end)
        end
        
        Notify("Script killed.")
    end
end)

