-- ─────────────────────────────────────────────────────────────
local TorsoCache    = {}   -- [userId] = BasePart
local HumanoidCache = {}   -- [userId] = Humanoid

local function FindTorso(char)
    return char:FindFirstChild("Torso")
        or char:FindFirstChild("UpperTorso")
        or char:FindFirstChild("HumanoidRootPart")
end

--[[
    WireCharacter — populates TorsoCache and HumanoidCache for a player.
    Clears both on CharacterAdded (new rig, parts not yet loaded) and retries
    once after 0.5 s for characters that are slow to fully replicate.
--]]
local function WireCharacter(player)
    local uid = player.UserId
    local function OnChar(char)
        TorsoCache[uid]    = nil
        HumanoidCache[uid] = nil
        local torso    = FindTorso(char)
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if torso    then TorsoCache[uid]    = torso    end
        if humanoid then HumanoidCache[uid] = humanoid end
        -- Retry once for slow-loading rigs
        if not torso or not humanoid then
            task.delay(0.5, function()
                if player.Character == char then
                    TorsoCache[uid]    = TorsoCache[uid]    or FindTorso(char)
                    HumanoidCache[uid] = HumanoidCache[uid] or char:FindFirstChildOfClass("Humanoid")
                end
            end)
        end
    end
    player.CharacterAdded:Connect(OnChar)
    if player.Character then OnChar(player.Character) end
end

