--  SECTION 1b — ARC CONE VISUALIZER
-- ═══════════════════════════════════════════════════════════════
--[[
    V4-5 (fixed): AP() no longer exists as a function at all.
    Arc point computation is fully inlined inside UpdateArcVis.
    Zero function allocations, zero closure captures per frame.

    V4-6: color writes guarded by lastArcColor dirty flag.
    V4-10: arcAngleDirty NOT triggered by size changes.

    Arc geometry formula (per segment endpoint i):
        c, s     = ArcAngles[i].c, ArcAngles[i].s
        arcDir.X = fwd.X*c + rgt.X*s
        arcDir.Y = fwd.Y*c + rgt.Y*s
        arcDir.Z = fwd.Z*c + rgt.Z*s
        point    = bpos + arcDir * reach
--]]

local ArcPool = {}

local function BuildArcVis()
    local old  = ArcPool
    local next = {}
    for i = 1, 2 + ARC_SEGS do
        local p = Instance.new("Part")
        p.Name="_NCBArc"; p.Anchored=true; p.CanCollide=false
        p.CastShadow=false; p.Massless=true
        p.Material=Enum.Material.Neon; p.Transparency=0.15
        p.Size=Vector3.new(0.07,0.07,1); p.Color=COLOR.CLEAR
        p.Parent=workspace
        next[i]=p
    end
    ArcPool = next
    lastArcColor = nil
    for _, p in ipairs(old) do pcall(p.Destroy, p) end
end

local function DestroyArcVis()
    local old = ArcPool; ArcPool={}; lastArcColor=nil
    for _, p in ipairs(old) do pcall(p.Destroy, p) end
end

--[[
    SetBeam — positions a neon Part between world points p1 and p2.
    Computes length and direction manually (no Vector3.Unit, no
    redundant magnitude call).
--]]
local function SetBeam(part, x1,y1,z1, x2,y2,z2, thick)
    local dx, dy, dz = x2-x1, y2-y1, z2-z1
    local len = math.sqrt(dx*dx + dy*dy + dz*dz)
    if len < 0.001 then part.Size=Vector3.new(0.001,0.001,0.001); return end
    local inv = 1/len
    part.Size  = Vector3.new(thick, thick, len)
    part.CFrame = CFrame.lookAt(
        Vector3.new((x1+x2)*0.5, (y1+y2)*0.5, (z1+z2)*0.5),
        Vector3.new((x1+x2)*0.5 + dx*inv, (y1+y2)*0.5 + dy*inv, (z1+z2)*0.5 + dz*inv)
    )
end

local function UpdateArcVis(baseCF, col)
    if not CFG.VisualizerEnabled then DestroyArcVis(); return end
    if #ArcPool == 0 then BuildArcVis() end
    if arcAngleDirty then RebuildArcAngles() end

    local reach = CFG.Size
    local bx,by,bz = baseCF.Position.X, baseCF.Position.Y, baseCF.Position.Z
    local fx,fy,fz = baseCF.LookVector.X, baseCF.LookVector.Y, baseCF.LookVector.Z
    local rx,ry,rz = baseCF.RightVector.X, baseCF.RightVector.Y, baseCF.RightVector.Z

    --[[
        V4-5: fully inlined arc point — no function call, no closure.
        Inline expansion of: point = bpos + (fwd*c + rgt*s) * reach
        Precompute all ARC_SEGS+1 endpoint world positions into a flat array.
        ptX[i], ptY[i], ptZ[i] = world coords of arc endpoint i.
    --]]
    local ptX, ptY, ptZ = {}, {}, {}
    for i = 1, ARC_SEGS + 1 do
        local a    = ArcAngles[i]
        local c, s = a.c, a.s
        ptX[i] = bx + (fx*c + rx*s) * reach
        ptY[i] = by + (fy*c + ry*s) * reach
        ptZ[i] = bz + (fz*c + rz*s) * reach
    end

    -- Radius lines: origin → left boundary, origin → right boundary
    SetBeam(ArcPool[1], bx,by,bz, ptX[1],ptY[1],ptZ[1], 0.09)
    SetBeam(ArcPool[2], bx,by,bz, ptX[ARC_SEGS+1],ptY[ARC_SEGS+1],ptZ[ARC_SEGS+1], 0.09)

    -- Arc boundary segments
    for i = 1, ARC_SEGS do
        SetBeam(ArcPool[2+i], ptX[i],ptY[i],ptZ[i], ptX[i+1],ptY[i+1],ptZ[i+1], 0.07)
    end

    -- V4-6: only write Color when it changes
    if col ~= lastArcColor then
        for i = 1, 2 + ARC_SEGS do ArcPool[i].Color = col end
        lastArcColor = col
    end
end

