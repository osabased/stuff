--[[
    ParseWhitelist — pure function; no side effects.
    Returns (set, count).  Handles CR+LF and LF line endings.
    Lines starting with # (after optional whitespace) are comments.
    Only positive integers are accepted.
--]]
local function ParseWhitelist(raw)
    local set, count = {}, 0
    for line in (raw .. "\n"):gmatch("([^\r\n]*)\r?\n") do
        local trimmed = line:match("^%s*(.-)%s*$")
        if trimmed == "" or trimmed:sub(1,1) == "#" then continue end
        local id = tonumber(trimmed)
        if id and id > 0 and id == math.floor(id) then
            set[id] = true
            count   = count + 1
        end
    end
    return set, count
end

local WL_MAX_RETRIES = 3

--[[
    FetchWhitelist — V4-3: guarded by isFetching to prevent concurrent
    runs.  V4-4: designed to be called AFTER BuildGUI so wlStatusLabel
    is guaranteed non-nil.  V4-11: resets WhitelistHits on success.

    Call with task.spawn(FetchWhitelist).
--]]
local function FetchWhitelist()
    if isFetching then return end
    isFetching = true

    local url = CFG.WhitelistURL
    if not url or url == "" then
        WhitelistStatus = "No URL set"
        if wlStatusLabel then wlStatusLabel.Text = WhitelistStatus end
        isFetching = false
        return
    end

    WhitelistStatus = "Loading..."
    if wlStatusLabel then wlStatusLabel.Text = WhitelistStatus end
    if wlRefLbl     then wlRefLbl.Text       = "..." end

    local delay   = 1
    local lastErr = "unknown"

    for attempt = 1, WL_MAX_RETRIES do
        if attempt > 1 then task.wait(delay); delay = delay * 2 end

        local ok, result = pcall(function() return game:HttpGet(url, true) end)

        if ok and type(result) == "string" and #result > 0 then
            local set, count = ParseWhitelist(result)
            -- Atomic swap: write both at once before any Heartbeat can read
            Whitelist             = set
            WhitelistStatus       = string.format("Loaded %d id%s", count, count==1 and "" or "s")
            -- V4-11: reset hit counter so it reflects the new list
            Stats.WhitelistHits   = 0
            WLInRangePrev         = {}

            if wlStatusLabel then wlStatusLabel.Text = WhitelistStatus end
            if wlRefLbl      then wlRefLbl.Text      = "REFRESH" end
            Notify(string.format("Whitelist: %d id%s loaded.", count, count==1 and "" or "s"))
            isFetching = false
            return
        else
            lastErr = tostring(result):sub(1, 60)
        end
    end

    WhitelistStatus = "Failed"
    if wlStatusLabel then
        wlStatusLabel.Text      = string.format("Failed (%d tries)", WL_MAX_RETRIES)
        wlStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
    if wlRefLbl then wlRefLbl.Text = "REFRESH" end
    warn("[NCB WL] All retries failed — last error: " .. lastErr)
    isFetching = false
end

