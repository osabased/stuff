local function FindKeybindConflict(nt)
    if nt.Kind ~= "Key" then return nil end   -- mouse buttons don't conflict with key binds
    local kb = CFG.Keybinds
    if nt.Code == kb.Toggle    then return "Toggle ("    .. tostring(kb.Toggle)    .. ")" end
