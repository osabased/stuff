-- ═══════════════════════════════════════════════════════════════
--  SECTION 3 — CORE DRAG ROUTINE
-- ═══════════════════════════════════════════════════════════════
--[[
    BUG-1:  _suppress/_restore share one cached connection list.
    BUG-2:  lerpCompleted flag gates the remote fire.
    PERF-B: CFG.LerpFrames snapshotted before the loop.
    EV-1:   _gc_baseline comparison unchanged.
    EV-4:   _S.* constants unchanged.
--]]
local function DragAndFire(victim, attackerRoot, remote, arcCF)
    local uid  = victim.UserId
    local char = victim.Character; if not char then return end
    local torso    = TorsoCache[uid]    or FindTorso(char)
    local humanoid = HumanoidCache[uid] or char:FindFirstChildOfClass(_S.Humanoid)
    if not torso or not humanoid then return end

    local victimName = victim.Name   -- EDGE-3 (v9): snapshot before any yield

    if humanoid.Health <= 0 then return end
    if humanoid:GetState() == Enum.HumanoidStateType.Dead then return end
    if ActiveDrags[uid] then return end
    if os.clock()-(LastDrag[uid] or 0) < CFG.DragCooldown then return end
    if not IsInFrontArc(arcCF, torso) then return end

    local realDist = (arcCF.Position - torso.Position).Magnitude
    ActiveDrags[uid]=true; LastDrag[uid]=os.clock(); Stats.ActiveDrags=Stats.ActiveDrags+1

    task.spawn(function()
        -- EV-1: validate getconnections against load-time baseline
        local _gc_live = typeof(getconnections)=="function" and getconnections or nil
        local _gc = (_gc_live ~= nil and _gc_live == _gc_baseline) and _gc_live or nil

        -- BUG-1: _makeSuppressor captures the connection list once in suppress(),
        --        reuses that exact list in restore().  No second getconnections call.
        local function _makeSuppressor(sig)
            local cached = nil
            local function suppress()
                if not _gc then return end
                local ok, conns = pcall(_gc, sig)
                if ok then
                    cached = conns
                    for _, c in ipairs(conns) do pcall(c.Disable, c) end
                end
            end
            local function restore()
                if not cached then return end
                for _, c in ipairs(cached) do pcall(c.Enable, c) end
                cached = nil
            end
            return suppress, restore
        end

        -- PERF-1 (v9): signals resolved once
        local torsoChangedSig = torso.Changed
        local torsoCFrameSig  = torso:GetPropertyChangedSignal("CFrame")

        local suppressChanged, restoreChanged = _makeSuppressor(torsoChangedSig)
        local suppressCFrame,  restoreCFrame  = _makeSuppressor(torsoCFrameSig)

        -- BUG-2: track whether the loop ran to completion
        local lerpCompleted = false

        -- PERF-B: snapshot LerpFrames once (avoids proxy metamethod per iteration)
        local lerpFrames = CFG.LerpFrames

        local ok, err = pcall(function()
            local dest = attackerRoot.CFrame * CFrame.new(1.2, 0, -2.8)
            local lp   = dest.Position - torso.Position
            if lp.Magnitude > 0.01 then
                torso.AssemblyLinearVelocity = lp.Unit
                    * math.clamp(lp.Magnitude * (60 / lerpFrames), 0, 55)
            end

            local origin = torso.CFrame
            for i = 1, lerpFrames do
                local targetCF = origin:Lerp(dest, (i/lerpFrames)^2)
                -- R-3: bracket only the single CFrame write per frame
                suppressChanged(); suppressCFrame()
                local wok = pcall(function() torso.CFrame = targetCF end)
                restoreCFrame(); restoreChanged()
                if not wok then break end   -- torso destroyed — stop cleanly
                if i == lerpFrames then lerpCompleted = true end
                RunService.Heartbeat:Wait()
            end
        end)

        -- BUG-2: fire remote only on a completed, error-free lerp
        if ok and lerpCompleted then
            if remote then
                pcall(function()
                    if remote:IsA(_S.RemoteEvent) then
                        remote:FireServer(victim)
                    elseif remote:IsA(_S.RemoteFunction) then
                        remote:InvokeServer(victim)
                    end
                end)
            end
            Stats.Kills=Stats.Kills+1; Stats.TotalDist=Stats.TotalDist+realDist
            Stats.LastVictim=victimName
        elseif not ok and CFG.Debug then
            -- REL-5: warn only in debug mode to avoid exposing line numbers
            warn(_S.DragPfx .. " drag error: " .. tostring(err))
        end

        Stats.ActiveDrags=math.max(0,Stats.ActiveDrags-1); ActiveDrags[uid]=nil
    end)
end

