--[[
    IsInFrontArc — one sqrt, one dot product, one compare.
    Uses cached cosAngleCap — no acos, no deg conversion.
--]]
local function IsInFrontArc(root, torso)
    local dx = torso.Position.X - root.Position.X
    local dy = torso.Position.Y - root.Position.Y
    local dz = torso.Position.Z - root.Position.Z
    local mag = math.sqrt(dx*dx + dy*dy + dz*dz)
    if mag < 0.1 then return false end
    local lv = root.CFrame.LookVector
    return (lv.X*dx + lv.Y*dy + lv.Z*dz) / mag >= cosAngleCap
end

