--[[
    IsTeammate — V5-2: reads PlayerTeamCache (zero property reads).
    Two nil-team players are NOT considered teammates (FFA scenario).
--]]
local function IsTeammate(player)
    if not CFG.IgnoreTeam then return false end
    if cachedLocalTeam == nil then return false end
    return PlayerTeamCache[player.UserId] == cachedLocalTeam
end

--[[
    IsTargetTeam — v8: returns true when the player should be PROCESSED
    given the current TargetTeam filter.
    If CFG.TargetTeam is nil, all players pass. Otherwise only players
    whose team matches CFG.TargetTeam are allowed through.
    Reads PlayerTeamCache — zero property reads.
--]]
local function IsTargetTeam(player)
    if CFG.TargetTeam == nil then return true end
    return PlayerTeamCache[player.UserId] == CFG.TargetTeam
end

--[[
    IsDead — v8: returns true if the humanoid is dead.
    Checked only when CFG.IgnoreDead is true.
--]]
local function IsDead(humanoid)
    return humanoid.Health <= 0
        or humanoid:GetState() == Enum.HumanoidStateType.Dead
end

--[[
    IsInvisible — v8: returns true if the cached torso's Transparency
    meets or exceeds CFG.InvisThreshold.
    Checked only when CFG.IgnoreInvisible is true.
--]]
local function IsInvisible(torso)
    return torso.Transparency >= CFG.InvisThreshold
end

--[[
    IsOverhealth — v8: returns true if the humanoid's health exceeds
    CFG.OverhealthCap.
    Checked only when CFG.IgnoreOverhealth is true.
--]]
local function IsOverhealth(humanoid)
    return humanoid.Health > CFG.OverhealthCap
end

local function IsWhitelisted(player)
    return Whitelist[player.UserId] == true
end

--[[
    IsInFrontArc — one sqrt, one dot, one compare.
    arcCF: composite CFrame (position = handle, rotation = root).
--]]
local function IsInFrontArc(arcCF, torso)
    local dx = torso.Position.X - arcCF.Position.X
    local dy = torso.Position.Y - arcCF.Position.Y
    local dz = torso.Position.Z - arcCF.Position.Z
    local mag = math.sqrt(dx*dx + dy*dy + dz*dz)
    if mag < 0.1 then return false end
    local lv = arcCF.LookVector
    return (lv.X*dx + lv.Y*dy + lv.Z*dz) / mag >= cosAngleCap
end

local function FindRemote(tool)
    local r = tool:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then return r end
    r = ReplicatedStorage:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then return r end
    return nil
end

