-- ============================================================================
-- SECTION 3 — CORE DRAG ROUTINE
-- ============================================================================

--[[
    DragAndFire(victim: Player, attackerRoot: Part, remote: Remote)
    Main drag logic - spawns a coroutine for each victim
    Flow:
    1. Validate victim still exists and has valid character
    2. Check cooldown and ActiveDrags table
    3. Verify victim is in front arc
    4. Record stats (distance)
    5. Spawn coroutine that:
       a. Suppresses torso signals
       b. Calculates destination (offset from attackerRoot)
       c. Applies velocity toward destination
       d. Lerps torso over CFG.LerpFrames
       e. Fires remote
       f. Restores signals
       g. Updates stats
    All operations wrapped in pcall for error safety
--]]
local function DragAndFire(victim, attackerRoot, remote)
    local uid  = victim.UserId
    local char = victim.Character
    
    -- Early validation
    if not char then return end
    if not char.Parent then return end  -- Character destroyed/respawning
    
    local torso    = char:FindFirstChild("Torso")
    local humanoid = char:FindFirstChild("Humanoid")
    
    if not torso or not humanoid or humanoid.Health<=0 then 
        return 
    end
    
    if ActiveDrags[uid] then 
        return  -- Already being dragged
    end
    
    if tick()-(LastDrag[uid] or 0) < CFG.DragCooldown then 
        return  -- Cooldown not elapsed
    end
    
    if not IsInFrontArc(attackerRoot, torso) then 
        return  -- Not in angle cone
    end
    
    if not CanDragVictim(victim) then
        return  -- Filter rejected
    end
    
    local realDist = (attackerRoot.Position - torso.Position).Magnitude
    
    -- Mark as active to prevent duplicate drags
    ActiveDrags[uid]=true
    LastDrag[uid]=tick()
    Stats.ActiveDrags = Stats.ActiveDrags+1
    
    -- Spawn drag coroutine
    coroutine.wrap(function()
        -- WRAP ENTIRE COROUTINE IN PCALL FOR ERROR HANDLING
        local success, err = pcall(function()
            -- Recalculate destination (in case attacker moved)
            local dest = attackerRoot.CFrame * CFrame.new(1.2, 0, -2.8)
            
            -- Verify torso still exists before suppressing signals
            if not torso or not torso.Parent then
                return
            end
            
            -- Suppress physics signals to prevent interference
            SuppressSignal(torso.Changed)
            SuppressSignal(torso:GetPropertyChangedSignal("CFrame"))
            
            -- Apply initial velocity toward destination
            local lp = dest.Position - torso.Position
            torso.AssemblyLinearVelocity = lp.Unit * math.clamp(lp.Magnitude/(CFG.LerpFrames/60),0,55)
            
            -- Save original position for lerping
            local origin = torso.CFrame
            
            -- Lerp torso to destination over CFG.LerpFrames
            for i = 1, CFG.LerpFrames do
                -- Check if torso still exists each frame
                if not torso or not torso.Parent then
                    break
                end
                
                -- Quadratic easing: (i/n)^2 for smoother start
                local t = (i/CFG.LerpFrames)^2
                torso.CFrame = origin:Lerp(dest, t)
                
                RunService.Heartbeat:Wait()
            end
            
            -- Restore physics signals
            RestoreSignal(torso.Changed)
            RestoreSignal(torso:GetPropertyChangedSignal("CFrame"))
            
            -- Fire remote if provided
            if remote then 
                pcall(function() 
                    remote:FireServer(victim) 
                end)
            end
            
            -- Update stats
            Stats.Kills      = Stats.Kills+1
            Stats.TotalDist  = Stats.TotalDist+realDist
            Stats.LastVictim = victim.Name
            
        end)
        
        -- Handle errors
        if not success then
            Stats.Errors = Stats.Errors + 1
            warn("[NoCBring] Drag error:", err)
        end
        
        -- Cleanup (always runs, even on error)
        Stats.ActiveDrags = math.max(0, Stats.ActiveDrags-1)
        ActiveDrags[uid] = nil
        
    end)()
end

-- ============================================================================
-- SECTION 4 — HEARTBEAT (MAIN LOOP)
-- ============================================================================

--[[
    Heartbeat runs at 60fps and handles:
    1. Stats refresh
    2. Character/tool validation
    3. Remote caching
    4. Trigger detection
    5. Player scanning with optimizations:
       - Spatial culling (skip beyond Size * 1.5)
       - Frame staggering (check 1/3 players per frame)
       - Early exit (stop if at MaxConcurrentDrags)
    6. Visualizer updates
    
    OPTIMIZATIONS:
    - Frame counter rotates through player list in 3-frame cycle
    - Spatial culling skips distant players before expensive checks
    - Cached FindFirstChild calls (handle, root, torso)
    - Early exit when trigger not held or disabled
--]]
Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    -- Refresh stats display
    if refreshStats then 
        refreshStats() 
    end
    
    -- Check if script killed
    if CFG.ScriptKilled then 
        return 
    end
    
    -- Get local character
    local char = LocalPlayer.Character
    if not char then 
        return 
    end
    
    -- Validate character components
    local tool     = char:FindFirstChildOfClass("Tool")
    local humanoid = char:FindFirstChild("Humanoid")
    local root     = char:FindFirstChild("HumanoidRootPart")
    
    if not tool or not humanoid or not root then
        currentRemote=nil
        DestroySphereVis()
        DestroyArcVis()
        return
    end
    
    local handle = tool:FindFirstChild("Handle")
    if not handle then 
        DestroySphereVis()
        DestroyArcVis()
        return 
    end
    
    -- Cache remote if not already cached
    if not currentRemote then 
        currentRemote = FindRemote(tool) 
    end
    
    -- Get trigger state
    local triggerHeld    = IsTriggerActive()
    local targetsInRange = 0
    
    -- Early exit if not enabled or trigger not held
    if not CFG.Enabled or not triggerHeld then
        -- Still update visualizers for feedback
        local col = CFG.Enabled and COLOR.CLEAR or COLOR.DISABLED
        UpdateSphereVis(handle, col)
        UpdateArcVis(root.CFrame, col)
        return
    end
    
    -- OPTIMIZATION: Frame staggering
    -- Only check 1/3 of players per frame to reduce CPU load
    frameCounter = (frameCounter + 1) % 3
    
    -- OPTIMIZATION: Spatial culling distance
    local cullDistance = CFG.Size * CFG.SpatialCullFactor
    
    -- Scan players
    local players = Players:GetPlayers()
    local playerCount = #players
    
    for i, player in ipairs(players) do
        -- Skip self
        if player==LocalPlayer then 
            continue 
        end
        
        -- OPTIMIZATION: Frame staggering - check different players each frame
        if CFG.FrameStagger and (i % 3) ~= frameCounter then
            continue
        end
        
        -- Get victim character and torso
        local pc = player.Character
        if not pc then 
            continue 
        end
        
        local pt = pc:FindFirstChild("Torso")
        if not pt then 
            continue 
        end
        
        -- OPTIMIZATION: Spatial culling - skip distant players
        local dist = (handle.Position - pt.Position).Magnitude
        if dist > cullDistance then
            continue
        end
        
        -- Check if in actual range
        if dist <= CFG.Size then
            targetsInRange = targetsInRange + 1
            
            -- OPTIMIZATION: Early exit if at max concurrent drags
            if Stats.ActiveDrags >= CFG.MaxConcurrentDrags then
                break
            end
            
            -- Initiate drag
            DragAndFire(player, root, currentRemote)
        end
    end
    
    -- Determine visualizer color state
    local col
    if not CFG.Enabled then
        col = COLOR.DISABLED
    elseif Stats.ActiveDrags > 0 then
        col = COLOR.FIRING
    elseif targetsInRange > 0 then
        col = COLOR.TARGET
    else
        col = COLOR.CLEAR
    end
    
    -- Update visualizers
    UpdateSphereVis(handle, col)
    UpdateArcVis(root.CFrame, col)
    
end)

