-- ═══════════════════════════════════════════════════════════════
--  SECTION 3 — CORE DRAG ROUTINE
-- ═══════════════════════════════════════════════════════════════
--[[
    V5-1: finally-pattern ensures RestoreSignal always runs.
    V5-6: task.spawn routes post-yield errors to task scheduler.
    EDGE-3:  victimName snapshotted before first yield.
    PERF-1:  CFrame signal resolved once; shared by Suppress + Restore.
    BUG-2:   remote:FireServer / InvokeServer branched on IsA.
--]]
local function DragAndFire(victim, attackerRoot, remote, arcCF)
    local uid  = victim.UserId
    local char = victim.Character; if not char then return end
    local torso    = TorsoCache[uid]    or FindTorso(char)
    local humanoid = HumanoidCache[uid] or char:FindFirstChildOfClass("Humanoid")
    if not torso or not humanoid then return end

    -- EDGE-3: snapshot name before any yield
    local victimName = victim.Name

    -- Safety guards (also enforced upstream in the Heartbeat filter chain)
    if humanoid.Health <= 0 then return end
    if humanoid:GetState() == Enum.HumanoidStateType.Dead then return end

    if ActiveDrags[uid] then return end
    if os.clock()-(LastDrag[uid] or 0) < CFG.DragCooldown then return end
    if not IsInFrontArc(arcCF, torso) then return end

    local realDist = (arcCF.Position - torso.Position).Magnitude
    ActiveDrags[uid]=true; LastDrag[uid]=os.clock(); Stats.ActiveDrags=Stats.ActiveDrags+1

    task.spawn(function()
        local suppressed = false

        -- PERF-1: resolve CFrame signal once; reused by both Suppress and Restore
        local torsoChangedSig = torso.Changed
        local torsoCFrameSig  = torso:GetPropertyChangedSignal("CFrame")

        local function cleanup()
            if suppressed then
                RestoreSignal(torsoChangedSig)
                RestoreSignal(torsoCFrameSig)
                suppressed = false
            end
        end

        local ok, err = pcall(function()
            local dest = attackerRoot.CFrame * CFrame.new(1.2, 0, -2.8)
            SuppressSignal(torsoChangedSig)
            SuppressSignal(torsoCFrameSig)
            suppressed = true

            local lp = dest.Position - torso.Position
            if lp.Magnitude > 0.01 then
                torso.AssemblyLinearVelocity = lp.Unit
                    * math.clamp(lp.Magnitude * (60 / CFG.LerpFrames), 0, 55)
            end

            local origin = torso.CFrame
            for i = 1, CFG.LerpFrames do
                torso.CFrame = origin:Lerp(dest, (i/CFG.LerpFrames)^2)
                RunService.Heartbeat:Wait()   -- EDGE-3: victim.Name NOT read after this
            end
        end)

        cleanup()   -- V5-1: unconditional

        if ok then
            -- BUG-2: branch on remote type; RemoteFunction uses InvokeServer
            if remote then
                pcall(function()
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer(victim)
                    elseif remote:IsA("RemoteFunction") then
                        remote:InvokeServer(victim)
                    end
                end)
            end
            Stats.Kills=Stats.Kills+1; Stats.TotalDist=Stats.TotalDist+realDist
            Stats.LastVictim=victimName   -- EDGE-3: pre-captured
        else
            warn("[NCB] drag error: " .. tostring(err))
        end

        Stats.ActiveDrags=math.max(0,Stats.ActiveDrags-1); ActiveDrags[uid]=nil
    end)
end

