--[[
    IsAlive — EDGE-2: Health fast-path retained, plus GetState() safety net.
    Custom rigs can enter Dead state before zeroing Health; both checks are
    needed for correctness outside the default Roblox health model.
--]]
local function IsAlive(hum)
    if not CFG.IgnoreDead then return true end
    if hum.Health <= 0 then return false end
    return hum:GetState() ~= Enum.HumanoidStateType.Dead
end

--[[
    IsVisible — EDGE-1: threshold now reads CFG.InvisThreshold (default 0.90)
    instead of the hardcoded 1.0.  Catches near-invisible characters that the
    old check passed silently.
--]]
local function IsVisible(torso)
    if not CFG.IgnoreInvisible then return true end
    return torso.Transparency < CFG.InvisThreshold
end

local function IsWithinHealthCap(hum)
    if CFG.MaxTargetHealth <= 0 then return true end
    return hum.Health <= CFG.MaxTargetHealth
end

local function IsWhitelisted(player)
    return Whitelist[player.UserId] == true
end

--[[
    IsInFrontArc — PERF-2: math.sqrt eliminated.
    Compares dot² ≥ cosAngCapSq × magSq (equivalent to dot/mag ≥ cosAngleCap
    when dot ≥ 0).  A dot < 0 fast-reject prunes targets strictly behind the
    player before the multiply.
--]]
local function IsInFrontArc(arcCF, torso)
    local dx = torso.Position.X - arcCF.Position.X
    local dy = torso.Position.Y - arcCF.Position.Y
    local dz = torso.Position.Z - arcCF.Position.Z
    local magSq = dx*dx + dy*dy + dz*dz
    if magSq < 0.01 then return false end   -- same 0.1-stud dead-zone, squared
    local lv  = arcCF.LookVector
    local dot = lv.X*dx + lv.Y*dy + lv.Z*dz
    if dot < 0 then return false end        -- fast reject: strictly behind
    return dot * dot >= cosAngCapSq * magSq
end

-- ─────────────────────────────────────────────────────────────
-- REMOTE DISCOVERY
-- ─────────────────────────────────────────────────────────────
-- EDGE-4 / BUG-3: cooldown stamp is written ONLY on failure.
-- If the remote is found, lastRemoteSearchTime is left unchanged so the next
-- nil-state (e.g. after a tool swap) retries immediately without waiting 1 s.
local lastRemoteSearchTime = -math.huge

local function FindRemote(tool)
    local now = os.clock()
    if now - lastRemoteSearchTime < 1 then return nil end
    local r = tool:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then return r end
    r = ReplicatedStorage:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then return r end
    lastRemoteSearchTime = now   -- EDGE-4: only stamped on failure
    return nil
end

