--[[
    MkFrame(parent, size, pos, color, z) → Frame
    Helper to create styled Frame with common properties
--]]
local function MkFrame(parent, size, pos, color, z)
    local f = Instance.new("Frame")
    f.Size = size
    f.Position = pos
    f.BackgroundColor3 = color or UI.PANEL
    f.BorderSizePixel = 0
    f.ZIndex = z or 1
    f.Parent = parent
    return f
end

--[[
    MkLabel(parent, text, size, pos, font, tsz, color, z, xa) → TextLabel
    Helper to create styled TextLabel with common properties
--]]
local function MkLabel(parent, text, size, pos, font, tsz, color, z, xa)
    local l = Instance.new("TextLabel")
    l.Size = size
    l.Position = pos
    l.Text = text
    l.Font = font or UI.FontBody
    l.TextSize = tsz or UI.TextSz
    l.TextColor3 = color or UI.TEXT
    l.BackgroundTransparency = 1
    l.ZIndex = z or 2
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.Parent = parent
    return l
end

