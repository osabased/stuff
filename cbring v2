-- CHARACTER WIRING (local player — clears remote cache on tool swap)
-- ─────────────────────────────────────────────────────────────
local function OnLocalChar(char)
    if wiredChars[char] then return end
    wiredChars[char] = true
    char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") then currentRemote = nil end
    end)
    char.ChildRemoved:Connect(function(c)
        if c:IsA("Tool") then currentRemote = nil; DestroyArcVis() end
    end)
    char.AncestryChanged:Connect(function()
        if not char.Parent then wiredChars[char] = nil end
    end)
end

