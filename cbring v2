-- ─────────────────────────────────────────────────────────────
-- WHITELIST FETCH
-- EDGE-2: each iteration checks ScriptKilled before waiting/fetching
-- EDGE-6: URL format validated before HttpGet
-- ─────────────────────────────────────────────────────────────
local function ParseWhitelist(raw)
    local set, count = {}, 0
    for line in raw:gmatch("([^\r\n]+)") do
        local t = line:match("^%s*(.-)%s*$")
        if t == "" or t:sub(1,1) == "#" then continue end
        local id = tonumber(t)
        if id and id > 0 and id == math.floor(id) then
            set[id] = true; count = count + 1
        end
    end
    return set, count
end

local function FetchWhitelist()
    if isFetching then return end
    isFetching = true
    local url = CFG.WhitelistURL
    if not url or url == "" then
        SetWLStatus("No URL set"); isFetching = false; return
    end
    -- EDGE-6: reject non-http(s) URLs before calling HttpGet
    if not url:match("^https?://") then
        SetWLStatus("Invalid URL"); isFetching = false; return
    end
    SetWLStatus("Loading...")
    if wlRefLbl then wlRefLbl.Text = "..." end
    local waitSec, lastErr = 1, "unknown"
    for attempt = 1, WL_MAX_RETRIES do
        -- EDGE-2: bail immediately if killed during a previous wait
        if CFG.ScriptKilled then isFetching = false; return end
        if attempt > 1 then
            task.wait(waitSec); waitSec = waitSec * 2
            -- Re-check after waking from sleep
            if CFG.ScriptKilled then isFetching = false; return end
        end
        local ok, result = pcall(function() return game:HttpGet(url, true) end)
        if ok and type(result) == "string" then
            Whitelist           = ParseWhitelist(result)
            local set, count    = Whitelist, 0
            -- recount for status message
            Whitelist, count    = ParseWhitelist(result)
            Stats.WhitelistHits = 0
            WLInRangePrev       = {}
            SetWLStatus(string.format("Loaded %d id%s", count, count==1 and "" or "s"))
            if wlRefLbl then wlRefLbl.Text = "REFRESH" end
            Notify(string.format("Whitelist: %d id%s loaded.", count, count==1 and "" or "s"))
            isFetching = false; return
        else
            lastErr = tostring(result)
        end
    end
    SetWLStatus(string.format("Failed (%d tries)", WL_MAX_RETRIES), Color3.fromRGB(255, 80, 80))
    if wlRefLbl then wlRefLbl.Text = "REFRESH" end
    warn(_S.WLPfx .. " All retries failed — last error: " .. lastErr)
    isFetching = false
end

