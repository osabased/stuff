--[[
    MkTeamDropdown — V8: live autocomplete team selector.

    Layout (relative to `par`):
      • "Target Team" label on the left.
      • TextBox on the right showing the current value (placeholder "All Teams").
      • Clicking or focusing the box opens a dropdown panel positioned directly
        below it.  The panel is clipped and scrolls if needed.
      • Each row in the dropdown is a clickable frame.  The first row is always
        "All Teams" (commits empty string → no filter).
      • Typing in the box filters rows in real-time (case-insensitive substring).
      • Pressing Enter or clicking a row commits the selection and closes the
        dropdown.  FocusLost without Enter restores the last committed value.
      • The dropdown is re-populated from Teams:GetTeams() each time it opens,
        so it reflects any teams added after the GUI was built.
--]]
local function MkTeamDropdown(par, y, onChange)
    local ROW_H   = 22   -- height of each dropdown row
    local MAX_VIS = 5    -- max rows shown before the panel clips
    local DD_PAD  = 4    -- vertical padding inside the dropdown

    MkLabel(par,"Target Team",UDim2.new(0,95,0,22),UDim2.new(0,UI.Pad,0,y),UI.FontBody,UI.TextSz,UI.MUTED,3)

    -- Input field
    local inputBG = MkFrame(par,UDim2.new(0,UI.W-116,0,24),UDim2.new(0,108,0,y+1),Color3.fromRGB(26,26,38),3)
    MkCorner(inputBG,4); MkStroke(inputBG,UI.BORDER,1)
    local box = Instance.new("TextBox")
    box.Size=UDim2.new(1,-8,1,0); box.Position=UDim2.new(0,4,0,0)
    box.Text=CFG.TargetTeam or ""; box.PlaceholderText="All Teams"
    box.PlaceholderColor3=UI.MUTED; box.Font=UI.FontBody; box.TextSize=11
    box.TextColor3=UI.WLC; box.BackgroundTransparency=1; box.BorderSizePixel=0
    box.ZIndex=4; box.ClearTextOnFocus=false; box.Parent=inputBG

    -- Dropdown panel (hidden until box is focused)
    local ddH  = ROW_H * MAX_VIS + DD_PAD * 2
    local ddBG = MkFrame(par,UDim2.new(0,UI.W-116,0,ddH),UDim2.new(0,108,0,y+27),Color3.fromRGB(20,20,30),8)
    MkCorner(ddBG,4); MkStroke(ddBG,UI.BORDER,1)
    ddBG.Visible=false; ddBG.ClipsDescendants=true

    -- Scrollable list inside the panel
    local listFrame = Instance.new("Frame")
    listFrame.Size=UDim2.new(1,0,0,0); listFrame.Position=UDim2.new(0,0,0,DD_PAD)
    listFrame.BackgroundTransparency=1; listFrame.ZIndex=9; listFrame.Parent=ddBG
    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder=Enum.SortOrder.LayoutOrder; listLayout.Parent=listFrame

    local ddOpen  = false
    local rowRefs = {}

    -- Collect team names: "" sentinel for "All Teams" + real team names
    local function GetTeamNames()
        local names = {""}
        for _, t in ipairs(Teams:GetTeams()) do names[#names+1] = t.Name end
        return names
    end

    local function CommitTeam(name)
        CFG.TargetTeam = name
        box.Text       = name
        ddBG.Visible   = false
        ddOpen         = false
        if onChange then onChange(name) end
    end

    -- Rebuild the row list filtered by `query` (empty = show all)
    local function RebuildList(query)
        for _, r in ipairs(rowRefs) do pcall(r.Destroy, r) end
        rowRefs = {}

        local names = GetTeamNames()
        local lo    = 0
        for _, name in ipairs(names) do
            local display = name == "" and "All Teams" or name
            if query == "" or display:lower():find(query:lower(), 1, true) then
                lo = lo + 1
                local rowBG = MkFrame(listFrame,UDim2.new(1,0,0,ROW_H),UDim2.new(0,0,0,0),Color3.fromRGB(0,0,0),9)
                rowBG.BackgroundTransparency=1; rowBG.LayoutOrder=lo
                MkLabel(rowBG,display,UDim2.new(1,-8,1,0),UDim2.new(0,6,0,0),UI.FontBody,11,
                    name == (CFG.TargetTeam or "") and UI.ACCENT or UI.TEXT, 10)
                rowBG.MouseEnter:Connect(function()
                    TweenService:Create(rowBG,TweenInfo.new(0.08),{BackgroundColor3=Color3.fromRGB(30,30,48),BackgroundTransparency=0}):Play()
                end)
                rowBG.MouseLeave:Connect(function()
                    TweenService:Create(rowBG,TweenInfo.new(0.08),{BackgroundTransparency=1}):Play()
                end)
                rowBG.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then CommitTeam(name) end
                end)
                table.insert(rowRefs, rowBG)
            end
        end

        -- Resize panel to fit visible rows
        listFrame.Size = UDim2.new(1,0,0,lo*ROW_H)
        ddBG.Size      = UDim2.new(0,UI.W-116,0,math.min(lo,MAX_VIS)*ROW_H+DD_PAD*2)
    end

    local function OpenDropdown()
        RebuildList("")  -- show all on initial open
        ddBG.Visible = true
        ddOpen       = true
    end

    local function CloseDropdown()
        ddBG.Visible = false
        ddOpen       = false
        box.Text     = CFG.TargetTeam or ""  -- restore committed value
    end

    -- Live filtering as the user types
    box:GetPropertyChangedSignal("Text"):Connect(function()
        if ddOpen then RebuildList(box.Text) end
    end)

    box.Focused:Connect(OpenDropdown)

    box.FocusLost:Connect(function(enter)
        -- Delay so a row click fires before this handler runs
        task.delay(0.15, function()
            if not ddOpen then return end   -- row click already closed it
            if enter then
                -- Try to match typed text to a real team name
                local typed = box.Text
                if typed == "" then
                    CommitTeam("")
                else
                    local matched = false
                    for _, t in ipairs(Teams:GetTeams()) do
                        if t.Name:lower() == typed:lower() then
                            CommitTeam(t.Name); matched=true; break
                        end
                    end
                    if not matched then CloseDropdown() end
                end
            else
                CloseDropdown()
            end
        end)
    end)

    return { SetTeam = CommitTeam }
end

