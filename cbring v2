local TorsoCache    = {}
local HumanoidCache = {}

local function FindTorso(char)
    return char:FindFirstChild(_S.Torso)
        or char:FindFirstChild(_S.UpperTorso)
        or char:FindFirstChild(_S.HRP)
end

local function WireCharacter(player)
    local uid = player.UserId
    -- BUG-4: disconnect stale connection before overwriting
    if CharAddedConns[uid] then CharAddedConns[uid]:Disconnect() end
    local function OnChar(char)
        TorsoCache[uid]    = nil
        HumanoidCache[uid] = nil
        local torso    = FindTorso(char)
        local humanoid = char:FindFirstChildOfClass(_S.Humanoid)
        if torso    then TorsoCache[uid]    = torso    end
        if humanoid then HumanoidCache[uid] = humanoid end
        if not torso or not humanoid then
            task.delay(0.5, function()
                if player.Parent == nil then return end
                local char2 = player.Character
                if char2 ~= char then return end
                -- REL-4: pcall wraps cache writes against mid-stream reset
                pcall(function()
                    TorsoCache[uid]    = TorsoCache[uid]    or FindTorso(char)
                    HumanoidCache[uid] = HumanoidCache[uid]
                        or char:FindFirstChildOfClass(_S.Humanoid)
                end)
            end)
        end
    end
    CharAddedConns[uid] = player.CharacterAdded:Connect(OnChar)
    if player.Character then OnChar(player.Character) end
end

