--  SECTION 3 — CORE DRAG ROUTINE
-- ═══════════════════════════════════════════════════════════════
local function DragAndFire(victim, attackerRoot, remote)
    local uid  = victim.UserId
    local char = victim.Character; if not char then return end
    local torso    = GetTorso(char); if not torso then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid"); if not humanoid then return end
    if humanoid.Health <= 0 then return end
    if humanoid:GetState() == Enum.HumanoidStateType.Dead then return end
    if ActiveDrags[uid] then return end
    if tick()-(LastDrag[uid] or 0) < CFG.DragCooldown then return end
    if not IsInFrontArc(attackerRoot, torso) then return end

    local realDist=(attackerRoot.Position-torso.Position).Magnitude
    ActiveDrags[uid]=true; LastDrag[uid]=tick(); Stats.ActiveDrags=Stats.ActiveDrags+1

    coroutine.wrap(function()
        local ok, err = pcall(function()
            local dest=attackerRoot.CFrame*CFrame.new(1.2,0,-2.8)
            SuppressSignal(torso.Changed)
            SuppressSignal(torso:GetPropertyChangedSignal("CFrame"))
            local lp=dest.Position-torso.Position
            torso.AssemblyLinearVelocity=lp.Unit*math.clamp(lp.Magnitude/(CFG.LerpFrames/60),0,55)
            local origin=torso.CFrame
            for i=1,CFG.LerpFrames do
                torso.CFrame=origin:Lerp(dest,(i/CFG.LerpFrames)^2)
                RunService.Heartbeat:Wait()
            end
            RestoreSignal(torso.Changed)
            RestoreSignal(torso:GetPropertyChangedSignal("CFrame"))
            if remote then pcall(function() remote:FireServer(victim) end) end
            Stats.Kills=Stats.Kills+1; Stats.TotalDist=Stats.TotalDist+realDist; Stats.LastVictim=victim.Name
        end)
        if not ok then warn("[NCB] drag error:",err) end
        Stats.ActiveDrags=math.max(0,Stats.ActiveDrags-1); ActiveDrags[uid]=nil
    end)()
end

-- ═══════════════════════════════════════════════════════════════
--  SECTION 4 — HEARTBEAT
-- ═══════════════════════════════════════════════════════════════
Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    -- Throttled stats refresh
    frameCount=frameCount+1
    if frameCount % STATS_THROTTLE == 0 and refreshStats then refreshStats() end

    if CFG.ScriptKilled then return end

    local char=LocalPlayer.Character; if not char then return end
    local tool=char:FindFirstChildOfClass("Tool")
    local root=char:FindFirstChild("HumanoidRootPart")
    if not tool or not root then currentRemote=nil; DestroySphereVis(); DestroyArcVis(); return end
    local handle=tool:FindFirstChild("Handle")
    if not handle then DestroySphereVis(); DestroyArcVis(); return end
    if not currentRemote then currentRemote=FindRemote(tool) end

    local triggerHeld    = IsTriggerActive()
    local targetsInRange = 0
    local wlInRange      = 0

    -- Localize hot-loop values
    local hx,hy,hz   = handle.Position.X, handle.Position.Y, handle.Position.Z
    local _sizeSq     = sizeSq
    local cache       = PlayerCache
    local wlNow       = {}   -- V4-2: players currently in WL range this frame

    for idx = 1, #cache do
        local player = cache[idx]
        local pc     = player.Character; if not pc then continue end
        local pt     = GetTorso(pc);     if not pt then continue end

        local dx=hx-pt.Position.X; local dy=hy-pt.Position.Y; local dz=hz-pt.Position.Z
        if dx*dx+dy*dy+dz*dz > _sizeSq then continue end

        if IsTeammate(player) then continue end

        local uid = player.UserId
        if IsWhitelisted(player) then
            wlInRange = wlInRange + 1
            wlNow[uid] = true
            -- V4-2: count only the 0→1 transition (player just entered range)
            if not WLInRangePrev[uid] then
                Stats.WhitelistHits = Stats.WhitelistHits + 1
            end
            continue
        end

        targetsInRange = targetsInRange + 1
        if CFG.Enabled and triggerHeld then
            DragAndFire(player, root, currentRemote)
        end
    end

    -- Swap WL range tracking for next frame
    WLInRangePrev = wlNow

    -- State color
    local col
    if not CFG.Enabled           then col=COLOR.DISABLED
    elseif Stats.ActiveDrags > 0 then col=COLOR.FIRING
    elseif targetsInRange > 0    then col=COLOR.TARGET
    elseif wlInRange > 0         then col=COLOR.WHITELIST
    else                              col=COLOR.CLEAR
    end

    UpdateSphereVis(handle, col)
    UpdateArcVis(root.CFrame, col)
end)

