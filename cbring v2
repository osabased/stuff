━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CORE FLOW:
1. Heartbeat runs every frame (60fps)
2. Checks if trigger is held (hotswappable input)
3. Scans players in range (with spatial culling + frame staggering)
4. For each valid target: calls DragAndFire()
5. DragAndFire() spawns a coroutine that:
   - Suppresses torso signals
   - Lerps torso to destination over CFG.LerpFrames
   - Fires remote
   - Restores signals
   - Updates stats

MEMORY MANAGEMENT:
- ActiveDrags[uid] = true during drag → prevents duplicate drags
- LastDrag[uid] = tick() → enforces cooldown
- PlayerRemoving cleans both tables
- Character connections disconnected on respawn

VISUALIZERS:
- Sphere: centered on Tool.Handle, shows reach radius
- Arc Cone: centered on HumanoidRootPart, shows AngleCap cone
- Both update every frame, color-coded by state

