--[[
    Visualizer showing CFG.AngleCap cone from HumanoidRootPart
    Uses 16 neon Parts in workspace:
    - ArcPool[1]: left radius line (from HRP to -AngleCap edge)
    - ArcPool[2]: right radius line (from HRP to +AngleCap edge)
    - ArcPool[3..16]: 14 arc segments tracing boundary curve
    
    Note: Arc is centered on HumanoidRootPart because angle check uses HRP.CFrame
    This makes the offset between handle position and body orientation visible
--]]

local ARC_SEGS = 14          -- Number of segments in arc boundary
local ArcPool  = {}          -- Pool of Parts for reuse

--[[
    SetBeam(part: Part, p1: Vector3, p2: Vector3, thick: number)
    Positions a Part as a beam between two points
    Uses CFrame.lookAt to orient part along the line
    Sets Size.Z to the distance between points (long axis)
    Size.X and Size.Y set to 'thick' for beam thickness
--]]
local function SetBeam(part, p1, p2, thick)
    local len = (p2 - p1).Magnitude
    if len < 0.001 then
        part.Size = Vector3.new(.001,.001,.001)
        return
    end
    
    local mid = (p1 + p2) / 2
    local dir = (p2 - p1).Unit
    
    part.Size   = Vector3.new(thick, thick, len)
    part.CFrame = CFrame.lookAt(mid, mid + dir)
end

--[[
    BuildArcVis()
    Creates 16 neon Parts for arc visualizer
    All parented to workspace, anchored, massless
    Initial color set to CLEAR (green)
--]]
local function BuildArcVis()
    for _, p in ipairs(ArcPool) do 
        pcall(function() p:Destroy() end) 
    end
    ArcPool = {}
    
    for i = 1, 2 + ARC_SEGS do
        local p = Instance.new("Part")
        p.Name = "_NCBArc"
        p.Anchored = true
        p.CanCollide = false
        p.CastShadow = false
        p.Massless = true
        p.Material = Enum.Material.Neon
        p.Transparency = 0.15
        p.Size = Vector3.new(.07,.07,1)
        p.Color = COLOR.CLEAR
        p.Parent = workspace
        ArcPool[i] = p
    end
end

--[[
    DestroyArcVis()
    Cleans up arc visualizer parts
    Called when visualizer disabled or script killed
--]]
local function DestroyArcVis()
    for _, p in ipairs(ArcPool) do 
        pcall(function() p:Destroy() end) 
    end
    ArcPool = {}
end

--[[
    UpdateArcVis(baseCF: CFrame, col: Color3)
    Recalculates all 16 arc parts every frame
    baseCF: HumanoidRootPart.CFrame (position + facing direction)
    col: Color state matching sphere
    
    ArcPoint(deg): Helper function that:
    - Rotates baseCF around local Y axis by 'deg' degrees
    - Returns position at CFG.Size distance along LookVector
    This traces the boundary of the acceptance cone in world space
    
    Updates:
    - Left/right radius lines (ArcPool[1], ArcPool[2])
    - 14 arc boundary segments (ArcPool[3..16])
--]]
local function UpdateArcVis(baseCF, col)
    if not CFG.VisualizerEnabled then 
        DestroyArcVis()
        return 
    end
    
    if #ArcPool == 0 then 
        BuildArcVis() 
    end
    
    local reach = CFG.Size
    local half  = CFG.AngleCap
    
    local function ArcPoint(deg)
        return baseCF.Position
            + (baseCF * CFrame.Angles(0, math.rad(deg), 0)).LookVector 
            * reach
    end
    
    local origin = baseCF.Position
    
    -- Left and right radius lines
    SetBeam(ArcPool[1], origin, ArcPoint(-half), 0.09)
    ArcPool[1].Color = col
    
    SetBeam(ArcPool[2], origin, ArcPoint( half), 0.09)
    ArcPool[2].Color = col
    
    -- Arc boundary segments (14 segments tracing the curve)
    for i = 1, ARC_SEGS do
        local a1   = -half + (2*half / ARC_SEGS) * (i-1)
        local a2   = -half + (2*half / ARC_SEGS) * i
        local part = ArcPool[2 + i]
        SetBeam(part, ArcPoint(a1), ArcPoint(a2), 0.07)
        part.Color = col
    end
end

