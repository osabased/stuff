--  SECTION 6 — CHARACTER & PLAYER EVENT WIRING
-- ══════════════════════════════════════════════════════════════════════════

-- Handle character events (tool added/removed)
local function OnChar(char)
    -- Clean up old connections if they exist
    if charConnections[char] then
        for _, conn in ipairs(charConnections[char]) do
            pcall(function() conn:Disconnect() end)
        end
        charConnections[char] = nil
    end
    
    local conns = {}
    
    -- Reset remote cache when tool is added
    table.insert(conns, char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") then
            currentRemote = nil
        end
    end))
    
    -- Reset remote and visualizers when tool is removed
    table.insert(conns, char.ChildRemoved:Connect(function(c)
        if c:IsA("Tool") then
            currentRemote = nil
            DestroyArcVis()
        end
    end))
    
    charConnections[char] = conns
end

-- Clean up player data when they leave (fixes memory leak)
Players.PlayerRemoving:Connect(function(player)
    ActiveDrags[player.UserId] = nil
    LastDrag[player.UserId] = nil
end)

-- Wire up current character and future characters
if LocalPlayer.Character then
    OnChar(LocalPlayer.Character)
end

LocalPlayer.CharacterAdded:Connect(OnChar)

-- Final notification
Notify(string.format("NoCBring v3  Size=%d  Trigger=%s  [C] UI",
    CFG.Size, CFG.TriggerInput.Name))

