--[[
    OnChar(char: Model)
    Sets up event handlers for character:
    - ChildAdded: invalidate remote cache when new tool added
    - ChildRemoved: invalidate cache and cleanup when tool removed
    
    CRITICAL FIX (v3.1):
    Disconnects old connections before creating new ones to prevent leaks
--]]
local function OnChar(char)
    -- CRITICAL: Disconnect old connections to prevent memory leak
    for _, c in pairs(charConnections) do
        pcall(function() c:Disconnect() end)
    end
    charConnections = {}
    
    -- Invalidate remote cache when tool added
    charConnections.ChildAdded = char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") then 
            currentRemote=nil 
        end
    end)
    
    -- Cleanup when tool removed
    charConnections.ChildRemoved = char.ChildRemoved:Connect(function(c)
        if c:IsA("Tool") then 
            currentRemote=nil
            DestroyArcVis()
        end
    end)
end

--[[
    PlayerRemoving cleanup
    CRITICAL FIX (v3.1):
    Cleans up ActiveDrags and LastDrag tables when player leaves
    Prevents memory leaks from orphaned entries
--]]
Connections.PlayerRemoving = Players.PlayerRemoving:Connect(function(player)
    ActiveDrags[player.UserId] = nil
    LastDrag[player.UserId] = nil
end)

-- Initialize character wiring
if LocalPlayer.Character then 
    OnChar(LocalPlayer.Character) 
end

Connections.CharacterAdded = LocalPlayer.CharacterAdded:Connect(OnChar)

-- Show startup notification
Notify(string.format("NoCBring v3.1  Size=%d  Trigger=%s  [C] UI",
    CFG.Size, CFG.TriggerInput.Name))

