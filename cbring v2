-- Disable all connections on a signal (used to prevent victim movement)
local function SuppressSignal(sig)
    for _, c in ipairs(getconnections(sig)) do
        pcall(function() c:Disable() end)
    end
end

-- Re-enable all connections on a signal (restore after drag)
local function RestoreSignal(sig)
    for _, c in ipairs(getconnections(sig)) do
        pcall(function() c:Enable() end)
    end
end

-- Check if victim is within the front-facing angle cone
-- Returns: boolean
local function IsInFrontArc(attackerRoot, victimTorso)
    -- Safety check: ensure parts exist and aren't too close
    if not attackerRoot or not victimTorso then return false end
    if not attackerRoot.Parent or not victimTorso.Parent then return false end
    
    local d = victimTorso.Position - attackerRoot.Position
    if d.Magnitude < 0.1 then return false end
    
    -- Calculate angle between attacker's forward direction and victim
    local angle = math.deg(math.acos(math.clamp(
        attackerRoot.CFrame.LookVector:Dot(d.Unit), -1, 1
    )))
    
    return angle <= CFG.AngleCap
end

-- Find the damage remote in tool or ReplicatedStorage
-- Returns: RemoteEvent/RemoteFunction or nil
local function FindRemote(tool)
    -- Search in tool first (more specific)
    local r = tool:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then
        return r
    end
    
    -- Fall back to ReplicatedStorage (broader search)
    r = ReplicatedStorage:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then
        return r
    end
    
    return nil
end

