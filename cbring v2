    DISABLED  = Color3.fromRGB(110, 110, 125),
    CLEAR     = Color3.fromRGB(0,   210, 110),
    TARGET    = Color3.fromRGB(255, 195, 0  ),
    FIRING    = Color3.fromRGB(255, 30,  55 ),
    WHITELIST = Color3.fromRGB(0,   180, 255),
}

local ArcPool = {}

--[[
    BuildArcVis — PERF-5: all properties set before p.Parent=workspace.
    Parenting last collapses N replication events into one per part.
--]]
local function BuildArcVis()
    local old = ArcPool; local nxt = {}
    for i = 1, 2 + ARC_SEGS do
        local p = Instance.new("Part")
        p.Name         = "_NCBArc"
        p.Anchored     = true
        p.CanCollide   = false
        p.CastShadow   = false
        p.Massless     = true
        p.Material     = Enum.Material.Neon
        p.Transparency = 0.15
        p.Size         = Vector3.new(0.07, 0.07, 1)
        p.Color        = COLOR.CLEAR
        p.Parent       = workspace   -- PERF-5: last
        nxt[i]         = p
    end
    ArcPool = nxt; lastArcColor = nil
    for _, p in ipairs(old) do pcall(p.Destroy, p) end
end

local function DestroyArcVis()
    local old = ArcPool; ArcPool = {}; lastArcColor = nil
    for _, p in ipairs(old) do pcall(p.Destroy, p) end
end

local function SetBeam(part, x1,y1,z1, x2,y2,z2, thick)
    local dx,dy,dz = x2-x1, y2-y1, z2-z1
    local len = math.sqrt(dx*dx+dy*dy+dz*dz)
    if len < 0.001 then part.Size=Vector3.new(0.001,0.001,0.001); return end
    local inv = 1/len
    part.Size   = Vector3.new(thick, thick, len)
    part.CFrame = CFrame.lookAt(
        Vector3.new((x1+x2)*0.5, (y1+y2)*0.5, (z1+z2)*0.5),
        Vector3.new((x1+x2)*0.5+dx*inv, (y1+y2)*0.5+dy*inv, (z1+z2)*0.5+dz*inv)
    )
end

local function UpdateArcVis(baseCF, col)
    if not CFG.VisualizerEnabled then DestroyArcVis(); return end
    if #ArcPool == 0 then BuildArcVis() end
    if arcAngleDirty then RebuildArcAngles() end
    local reach       = CFG.Size
    local bx,by,bz   = baseCF.Position.X,   baseCF.Position.Y,   baseCF.Position.Z
    local fx,fy,fz   = baseCF.LookVector.X,  baseCF.LookVector.Y,  baseCF.LookVector.Z
    local rx,ry,rz   = baseCF.RightVector.X, baseCF.RightVector.Y, baseCF.RightVector.Z
    for i = 1, ARC_SEGS+1 do
        local c, s  = arcCosTable[i], arcSinTable[i]
        arcPtX[i]   = bx + (fx*c + rx*s) * reach
        arcPtY[i]   = by + (fy*c + ry*s) * reach
        arcPtZ[i]   = bz + (fz*c + rz*s) * reach
    end
    SetBeam(ArcPool[1], bx,by,bz, arcPtX[1],           arcPtY[1],           arcPtZ[1],           0.09)
    SetBeam(ArcPool[2], bx,by,bz, arcPtX[ARC_SEGS+1],  arcPtY[ARC_SEGS+1],  arcPtZ[ARC_SEGS+1],  0.09)
    for i = 1, ARC_SEGS do
        SetBeam(ArcPool[2+i], arcPtX[i],arcPtY[i],arcPtZ[i], arcPtX[i+1],arcPtY[i+1],arcPtZ[i+1], 0.07)
    end
    if col ~= lastArcColor then
        for i = 1, 2+ARC_SEGS do ArcPool[i].Color = col end
        lastArcColor = col
    end
end

