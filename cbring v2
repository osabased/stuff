--[[
    ArcAngles[i] = { c=cos, s=sin }  for i in 1..ARC_SEGS+1
    Indexed from left boundary (-AngleCap) to right (+AngleCap).
    Rebuilt only when AngleCap changes.
--]]
local ARC_SEGS      = 14
local ArcAngles     = {}
local arcAngleDirty = true

local function RebuildArcAngles()
    local half = CFG.AngleCap
    for i = 0, ARC_SEGS do
        local rad = math.rad(-half + (2 * half / ARC_SEGS) * i)
        ArcAngles[i+1] = { c = math.cos(rad), s = math.sin(rad) }
    end
    arcAngleDirty = false
end

