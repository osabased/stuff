-- V4-1: single correct definition, no duplicate
local function BuildSphereVis()
    if VisPart then VisPart:Destroy() end
    local p = Instance.new("Part")
    p.Name="._NCBSp"; p.Anchored=false; p.CanCollide=false
    p.Massless=true; p.Transparency=1; p.Size=Vector3.new(1,1,1)
