local function MkTeamDropdown(par, y, onChange)
    local ROW_H   = 22
    local MAX_VIS = 5
    local DD_PAD  = 4

    MkLabel(par,"Target Team",UDim2.new(0,95,0,22),UDim2.new(0,UI.Pad,0,y),UI.FontBody,UI.TextSz,UI.MUTED,3)
    local inputBG = MkFrame(par,UDim2.new(0,UI.W-116,0,24),UDim2.new(0,108,0,y+1),Color3.fromRGB(26,26,38),3)
    MkCorner(inputBG,4); MkStroke(inputBG,UI.BORDER,1)
    local box = Instance.new("TextBox")
    box.Size=UDim2.new(1,-8,1,0); box.Position=UDim2.new(0,4,0,0)
    box.Text=CFG.TargetTeam and CFG.TargetTeam.Name or ""
    box.PlaceholderText="All Teams"; box.PlaceholderColor3=UI.MUTED
    box.Font=UI.FontBody; box.TextSize=11; box.TextColor3=UI.WLC
    box.BackgroundTransparency=1; box.BorderSizePixel=0; box.ZIndex=4
    box.ClearTextOnFocus=false; box.Parent=inputBG

    local ddH  = ROW_H * MAX_VIS + DD_PAD * 2
    local ddBG = Instance.new("Frame")
    ddBG.Size=UDim2.new(0,UI.W-116,0,ddH); ddBG.BackgroundColor3=Color3.fromRGB(20,20,30)
    ddBG.BorderSizePixel=0; ddBG.ZIndex=20; ddBG.Visible=false; ddBG.ClipsDescendants=true
    MkCorner(ddBG,4); MkStroke(ddBG,UI.BORDER,1)

    local listFrame = Instance.new("Frame")
    listFrame.Size=UDim2.new(1,0,0,0); listFrame.Position=UDim2.new(0,0,0,DD_PAD)
    listFrame.BackgroundTransparency=1; listFrame.ZIndex=21; listFrame.Parent=ddBG
    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder=Enum.SortOrder.LayoutOrder; listLayout.Parent=listFrame

    local ddOpen       = false
    local rowCache     = {}
    local clickPending = false

    local function CommitTeam(teamObj)
        CFG.TargetTeam = teamObj
        box.Text       = teamObj and teamObj.Name or ""
        ddBG.Visible   = false; ddOpen = false
        if onChange then onChange(teamObj) end
    end

    local function BuildRowCache()
        for _, r in ipairs(rowCache) do pcall(r.frame.Destroy, r.frame) end
        rowCache = {}
        local items = {{teamObj=nil, display="All Teams"}}
        for _, t in ipairs(Teams:GetTeams()) do items[#items+1] = {teamObj=t, display=t.Name} end
        for i, item in ipairs(items) do
            local rowBG = MkFrame(listFrame,UDim2.new(1,0,0,ROW_H),UDim2.new(0,0,0,0),Color3.fromRGB(0,0,0),21)
            rowBG.BackgroundTransparency=1; rowBG.LayoutOrder=i
            MkLabel(rowBG,item.display,UDim2.new(1,-8,1,0),UDim2.new(0,6,0,0),UI.FontBody,11,
                item.teamObj==CFG.TargetTeam and UI.ACCENT or UI.TEXT,22)
            -- PERF-D: DD_ROW_TWEEN is module-level, not allocated per hover
            rowBG.MouseEnter:Connect(function()
                TweenService:Create(rowBG,DD_ROW_TWEEN,{BackgroundColor3=Color3.fromRGB(30,30,48),BackgroundTransparency=0}):Play()
            end)
            rowBG.MouseLeave:Connect(function()
                TweenService:Create(rowBG,DD_ROW_TWEEN,{BackgroundTransparency=1}):Play()
            end)
            rowBG.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                    clickPending=true; CommitTeam(item.teamObj)
                end
            end)
            -- EDGE-5/PERF-C: pre-compute lowercased display string
            rowCache[#rowCache+1] = {
                frame      = rowBG,
                teamObj    = item.teamObj,
                display    = item.display,
                displayLow = item.display:lower(),
            }
        end
    end

    -- EDGE-5/PERF-C: uses pre-computed displayLow, no per-keystroke allocation
    local function FilterRows(query)
        local lo  = query:lower()
        local vis = 0
        for _, r in ipairs(rowCache) do
            local show = (lo=="" or r.displayLow:find(lo,1,true)~=nil)
            r.frame.Visible = show
            if show then vis = vis+1 end
        end
        listFrame.Size = UDim2.new(1,0,0,vis*ROW_H)
        ddBG.Size      = UDim2.new(0,UI.W-116,0,math.min(vis,MAX_VIS)*ROW_H+DD_PAD*2)
    end

    local function OpenDropdown()
        if winRef then ddBG.Parent = winRef end
        BuildRowCache(); FilterRows("")
        ddBG.Visible=true; ddOpen=true
        task.defer(function()
            if not ddOpen or not winRef then return end
            local abs    = inputBG.AbsolutePosition
            local winAbs = winRef.AbsolutePosition
            ddBG.Position = UDim2.new(0, abs.X-winAbs.X, 0, abs.Y-winAbs.Y+26)
        end)
    end

    local function CloseDropdown()
        ddBG.Visible=false; ddOpen=false
        box.Text = CFG.TargetTeam and CFG.TargetTeam.Name or ""
    end

    box:GetPropertyChangedSignal("Text"):Connect(function()
        if ddOpen then FilterRows(box.Text) end
    end)
    box.Focused:Connect(OpenDropdown)
    box.FocusLost:Connect(function(enter)
        task.defer(function()
            if CFG.ScriptKilled then return end
            if clickPending then clickPending=false; return end
            if not ddOpen then return end
            if enter then
                local typed = box.Text
                if typed=="" then CommitTeam(nil)
                else
                    local matched=false
                    for _, t in ipairs(Teams:GetTeams()) do
                        if t.Name:lower()==typed:lower() then CommitTeam(t);matched=true;break end
                    end
                    if not matched then CloseDropdown() end
                end
            else
                CloseDropdown()
            end
        end)
    end)
    return { SetTeam = CommitTeam }
end

-- REL-3: cancel all in-flight GUI tweens before a destroy
local function CancelGUITweens()
    for _, fn in ipairs(_guiTweenCancellers) do pcall(fn) end
    table.clear(_guiTweenCancellers)
end

