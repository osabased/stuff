-- ═══════════════════════════════════════════════════════════════
--  SECTION 3 — CORE DRAG ROUTINE
-- ═══════════════════════════════════════════════════════════════
--[[
    M-5: getconnections resolved lazily inside task.spawn.
         The function is in the environment only during an active drag.
    R-3: suppress/restore bracket only the single torso.CFrame write
         per lerp frame, not the whole loop.  Signal gap = ~1 tick per frame
         rather than the full lerp duration.
    EDGE-3: victimName snapshotted before first yield.
    PERF-1: torso Changed + CFrame signals resolved once.
    BUG-2:  FireServer vs InvokeServer branched on IsA.
--]]
local function DragAndFire(victim, attackerRoot, remote, arcCF)
    local uid  = victim.UserId
    local char = victim.Character; if not char then return end
    local torso    = TorsoCache[uid]    or FindTorso(char)
    local humanoid = HumanoidCache[uid] or char:FindFirstChildOfClass("Humanoid")
    if not torso or not humanoid then return end

    local victimName = victim.Name   -- EDGE-3: snapshot before any yield

    if humanoid.Health <= 0 then return end
    if humanoid:GetState() == Enum.HumanoidStateType.Dead then return end
    if ActiveDrags[uid] then return end
    if os.clock()-(LastDrag[uid] or 0) < CFG.DragCooldown then return end
    if not IsInFrontArc(arcCF, torso) then return end

    local realDist = (arcCF.Position - torso.Position).Magnitude
    ActiveDrags[uid]=true; LastDrag[uid]=os.clock(); Stats.ActiveDrags=Stats.ActiveDrags+1

    task.spawn(function()
        -- M-5: resolve getconnections lazily — only referenced during this drag window
        local _gc = typeof(getconnections)=="function" and getconnections or nil

        local function _suppress(sig)
            if not _gc then return end
            local ok, conns = pcall(_gc, sig)
            if ok then for _, c in ipairs(conns) do pcall(c.Disable, c) end end
        end
        local function _restore(sig)
            if not _gc then return end
            local ok, conns = pcall(_gc, sig)
            if ok then for _, c in ipairs(conns) do pcall(c.Enable, c) end end
        end

        -- PERF-1: signals resolved once; shared by all per-frame suppress/restore calls
        local torsoChangedSig = torso.Changed
        local torsoCFrameSig  = torso:GetPropertyChangedSignal("CFrame")

        local ok, err = pcall(function()
            local dest = attackerRoot.CFrame * CFrame.new(1.2, 0, -2.8)
            local lp   = dest.Position - torso.Position
            if lp.Magnitude > 0.01 then
                torso.AssemblyLinearVelocity = lp.Unit
                    * math.clamp(lp.Magnitude * (60 / CFG.LerpFrames), 0, 55)
            end

            local origin = torso.CFrame
            for i = 1, CFG.LerpFrames do
                local targetCF = origin:Lerp(dest, (i/CFG.LerpFrames)^2)
                -- R-3: narrow suppression window — one torso.CFrame write bracketed per frame
                _suppress(torsoChangedSig)
                _suppress(torsoCFrameSig)
                local wok = pcall(function() torso.CFrame = targetCF end)
                _restore(torsoCFrameSig)    -- R-3: always restores regardless of write result
                _restore(torsoChangedSig)
                if not wok then break end   -- torso destroyed mid-lerp; stop cleanly
                RunService.Heartbeat:Wait()
            end
        end)
        -- R-3: no outer cleanup required; every suppress is balanced by a restore above

        if ok then
            -- BUG-2: branch on remote type
            if remote then
                pcall(function()
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer(victim)
                    elseif remote:IsA("RemoteFunction") then
                        remote:InvokeServer(victim)
                    end
                end)
            end
            Stats.Kills=Stats.Kills+1; Stats.TotalDist=Stats.TotalDist+realDist
            Stats.LastVictim=victimName
        else
            warn("[NCB] drag error: " .. tostring(err))
        end

        Stats.ActiveDrags=math.max(0,Stats.ActiveDrags-1); ActiveDrags[uid]=nil
    end)
end

-- ─────────────────────────────────────────────────────────────
-- M-2: FUNCTION IDENTITY SEAL
-- Wrap all hot-path functions in newcclosure after definition.
-- Each session gets unique bytecode; static hash databases find no match.
-- Graceful identity fallback when newcclosure is unavailable.
-- ─────────────────────────────────────────────────────────────
do
    local _nc = typeof(newcclosure)=="function" and newcclosure or function(f) return f end
    IsTeammate        = _nc(IsTeammate)
    IsTargetTeam      = _nc(IsTargetTeam)
    IsAlive           = _nc(IsAlive)
    IsVisible         = _nc(IsVisible)
    IsWithinHealthCap = _nc(IsWithinHealthCap)
    IsWhitelisted     = _nc(IsWhitelisted)
    IsInFrontArc      = _nc(IsInFrontArc)
    WireCharacter     = _nc(WireCharacter)
    FindRemote        = _nc(FindRemote)
    DragAndFire       = _nc(DragAndFire)
end

-- ═══════════════════════════════════════════════════════════════
--  SECTION 4 — HEARTBEAT
-- ═══════════════════════════════════════════════════════════════
Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    if CFG.ScriptKilled then return end

    frameCount=frameCount+1
    if frameCount % STATS_THROTTLE == 0 and refreshStats then refreshStats() end

    -- EDGE-11: reset frame counter before float precision degrades
    if wlFrameId >= 9e15 then wlFrameId=1; WLInRangePrev={} end

    local char=LocalPlayer.Character; if not char then return end
    local tool=ToolCache[LocalPlayer]   -- EDGE-10: O(1) lookup
    local root=char:FindFirstChild("HumanoidRootPart")
    if not tool or not root then
        currentRemote=nil; lastRemoteSearchTime=-math.huge
        arcStillCount=0; DestroyArcVis(); return
    end
    local handle=tool:FindFirstChild("Handle")
    if not handle then DestroyArcVis(); return end

    -- N-4: only probe for remote during active sessions; no probing when idle
    if not currentRemote then
        if os.clock() - lastActiveTime <= IDLE_TIMEOUT then
            currentRemote = FindRemote(tool)
        end
    end

    local arcCF = root.CFrame + (handle.Position - root.Position)

    -- D-4: track character velocity to detect stillness
    if CFG.ArcHideStill then
        local vel = root.AssemblyLinearVelocity
        if vel.X*vel.X + vel.Y*vel.Y + vel.Z*vel.Z < ARC_STILL_VEL_SQ then
            arcStillCount = arcStillCount + 1
        else
            arcStillCount = 0
        end
    else
        arcStillCount = 0
    end

    local triggerHeld    = IsTriggerActive()
    local targetsInRange = 0
    local wlInRange      = 0

    local hx,hy,hz  = handle.Position.X, handle.Position.Y, handle.Position.Z
    local _sizeSq   = sizeSq
    local cache     = PlayerCache
    local _humCache = HumanoidCache

    wlFrameId = wlFrameId + 1
    local prevFrameId = wlFrameId - 1

    for idx = 1, #cache do
        local player = cache[idx]
        local pc     = player.Character; if not pc then continue end
        local uid    = player.UserId

        local pt = TorsoCache[uid]; if not pt then continue end

        local dx=hx-pt.Position.X; local dy=hy-pt.Position.Y; local dz=hz-pt.Position.Z
        if dx*dx+dy*dy+dz*dz > _sizeSq then continue end

        -- ── FILTER CHAIN ────────────────────────────────────
        if IsTeammate(player)       then continue end
        if not IsTargetTeam(player) then continue end
        local hum = _humCache[uid]; if not hum then continue end
        if not IsAlive(hum)           then continue end
        if not IsVisible(pt)          then continue end
        if not IsWithinHealthCap(hum) then continue end
        -- ────────────────────────────────────────────────────

        if IsWhitelisted(player) then
            wlInRange = wlInRange + 1
            if WLInRangePrev[uid] ~= prevFrameId then
                Stats.WhitelistHits = Stats.WhitelistHits + 1
            end
            WLInRangePrev[uid] = wlFrameId
            continue
        end

        targetsInRange = targetsInRange + 1
        if CFG.Enabled and triggerHeld then
            lastActiveTime = os.clock()   -- N-4: reset idle timer on active fire
            DragAndFire(player, root, currentRemote, arcCF)
        end
    end

    local col
    if not CFG.Enabled           then col=COLOR.DISABLED
    elseif Stats.ActiveDrags > 0 then col=COLOR.FIRING
    elseif targetsInRange > 0    then col=COLOR.TARGET
    elseif wlInRange > 0         then col=COLOR.WHITELIST
    else                              col=COLOR.CLEAR
    end

    -- D-4: skip arc entirely while character is stationary (destroys existing parts)
    if CFG.ArcHideStill and arcStillCount > ARC_STILL_HOLD then
        DestroyArcVis()
    else
        UpdateArcVis(arcCF, col)
    end
end)

-- ═══════════════════════════════════════════════════════════════
--  SECTION 5 — INPUT / KEYBINDS
-- ═══════════════════════════════════════════════════════════════
Connections.Input = UIS.InputBegan:Connect(function(input, gpe)
    if listeningForTrigger then
        if os.clock()-rebindStartTick < 0.10 then return end
        if input.KeyCode==Enum.KeyCode.Escape then
            listeningForTrigger=false
            if triggerBindLabel then triggerBindLabel.Text=CFG.TriggerInput.Name; triggerBindLabel.TextColor3=UI.ACCENT end
            if _rebindUIRef then
                _rebindUIRef.rbLbl.TextColor3=UI.MUTED
                _rebindUIRef.rbStroke.Color=UI.BORDER
                _rebindUIRef.chipStroke.Color=UI.ACCENT
            end
            Notify("Rebind cancelled."); return
        end
        local nt
        if     input.UserInputType==Enum.UserInputType.MouseButton1 then nt={Kind="Mouse",Button=Enum.UserInputType.MouseButton1,Name="M1"}
        elseif input.UserInputType==Enum.UserInputType.MouseButton2 then nt={Kind="Mouse",Button=Enum.UserInputType.MouseButton2,Name="M2"}
        elseif input.UserInputType==Enum.UserInputType.MouseButton3 then nt={Kind="Mouse",Button=Enum.UserInputType.MouseButton3,Name="M3"}
        elseif input.KeyCode~=Enum.KeyCode.Unknown then nt={Kind="Key",Code=input.KeyCode,Name=InputToName(input)}
        else return end

        -- QoL-7: conflict check before committing rebind
        local conflict = FindKeybindConflict(nt)
        if conflict then
            listeningForTrigger = false
            if triggerBindLabel then
                triggerBindLabel.Text       = "CONFLICT"
                triggerBindLabel.TextColor3 = UI.WARN
                task.delay(1.5, function()
                    if not CFG.ScriptKilled and triggerBindLabel then
                        triggerBindLabel.Text       = CFG.TriggerInput.Name
                        triggerBindLabel.TextColor3 = UI.ACCENT
                    end
                end)
            end
            if _rebindUIRef then
                _rebindUIRef.rbLbl.TextColor3   = UI.WARN
                _rebindUIRef.rbStroke.Color     = UI.WARN
                _rebindUIRef.chipStroke.Color   = UI.WARN
                task.delay(1.5, function()
                    if not CFG.ScriptKilled and _rebindUIRef then
                        _rebindUIRef.rbLbl.TextColor3 = UI.MUTED
                        _rebindUIRef.rbStroke.Color   = UI.BORDER
                        _rebindUIRef.chipStroke.Color = UI.ACCENT
                    end
                end)
            end
            Notify("Conflict: already bound to " .. conflict)
            return
        end

        -- No conflict — commit
        CFG.TriggerInput=nt; listeningForTrigger=false
        if triggerBindLabel then triggerBindLabel.Text=nt.Name; triggerBindLabel.TextColor3=UI.ACCENT end
        if _rebindUIRef then
            _rebindUIRef.rbLbl.TextColor3=UI.MUTED
            _rebindUIRef.rbStroke.Color=UI.BORDER
            _rebindUIRef.chipStroke.Color=UI.ACCENT
        end
        Notify("Trigger → "..nt.Name); return
    end

    if gpe then return end
    if input.KeyCode==CFG.Keybinds.Toggle then
        CFG.Enabled=not CFG.Enabled
        if toggles.Enabled then toggles.Enabled.SetState(CFG.Enabled) end
        Notify("Enabled: "..tostring(CFG.Enabled))
    elseif input.KeyCode==CFG.Keybinds.ToggleVis then
        CFG.VisualizerEnabled=not CFG.VisualizerEnabled
        if toggles.Visualizer then toggles.Visualizer.SetState(CFG.VisualizerEnabled) end
        if not CFG.VisualizerEnabled then DestroyArcVis() end
        Notify("Visualizer: "..tostring(CFG.VisualizerEnabled))
    elseif input.KeyCode==CFG.Keybinds.ToggleUI then
        -- D-3: destroy the ScreenGui instance entirely; rebuild on demand
        if ScreenGui then
            ScreenGui:Destroy()
            ScreenGui=nil; winRef=nil; shadowRef=nil
            guiVisible=false
        else
            BuildGUI()
            guiVisible=true
        end
    elseif input.KeyCode==CFG.Keybinds.Kill then
        CFG.ScriptKilled=true
        DestroyArcVis()

        -- D-4: clean up owned arc folder
        if arcFolderOwned and arcFolder and arcFolder.Parent then
            pcall(arcFolder.Destroy, arcFolder)
        end
        arcFolder=nil; arcFolderOwned=false

        if ScreenGui then ScreenGui:Destroy(); ScreenGui=nil end
        for _,c in pairs(Connections)     do pcall(c.Disconnect,c) end
        for _,c in pairs(PlayerTeamConns) do pcall(c.Disconnect,c) end
        for _,c in pairs(CharAddedConns)  do pcall(c.Disconnect,c) end
        for _,c in ipairs(localCharConns) do pcall(c.Disconnect,c) end  -- EDGE-6

        -- M-3: scrub all sensitive cache tables in-place
        table.clear(TorsoCache)
        table.clear(HumanoidCache)
        table.clear(PlayerTeamCache)
        table.clear(PlayerCache)
        table.clear(Whitelist)
        table.clear(ActiveDrags)
        table.clear(LastDrag)
        table.clear(WLInRangePrev)
        -- M-3: zero sensitive config fields
        _cfgReal.WhitelistURL = ""
        _cfgReal.RemoteName   = ""
        -- M-3: remove session keys from global environment
        getgenv()[_cfgKey]   = nil
        getgenv()[_guardKey] = nil

        Notify("Script killed.")
    end
end)

-- ─────────────────────────────────────────────────────────────
-- CHARACTER WIRING — LOCAL PLAYER
-- EDGE-6: connections in localCharConns for kill teardown
-- EDGE-10: ToolCache maintained via ChildAdded/Removed
-- ─────────────────────────────────────────────────────────────
local function OnChar(char)
    if wiredChars[char] then return end
    wiredChars[char] = true

    ToolCache[LocalPlayer] = nil
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then ToolCache[LocalPlayer] = c; break end
    end

    localCharConns[#localCharConns+1] = char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") then
            ToolCache[LocalPlayer] = c
            currentRemote = nil
        end
    end)
    localCharConns[#localCharConns+1] = char.ChildRemoved:Connect(function(c)
        if c:IsA("Tool") then
            ToolCache[LocalPlayer]   = nil
            currentRemote            = nil
            lastRemoteSearchTime     = -math.huge
            DestroyArcVis()
        end
    end)
    localCharConns[#localCharConns+1] = char.AncestryChanged:Connect(function()
        if not char.Parent then
            wiredChars[char]       = nil
            ToolCache[LocalPlayer] = nil
        end
    end)
