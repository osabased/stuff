local function BuildArcVis()
    local old      = ArcPool
    local nxt      = {}
    local partName = RandName()
    local arcParent = GetArcFolder()
    for i = 1, ARC_TOTAL do
        local p = Instance.new("Part")
        p.Name         = partName
        p.Anchored     = true
        p.CanCollide   = false
        p.CastShadow   = false
        p.Massless     = true
        p.Material     = Enum.Material.Neon
        p.Transparency = 0.15
        p.Size         = Vector3.new(0.07, 0.07, 1)
        p.Color        = COLOR.CLEAR
        p.Parent       = arcParent
        nxt[i]         = p
    end
    -- EDGE-1: only commit if all parts were created
    if #nxt == ARC_TOTAL then
        ArcPool = nxt; lastArcColor = nil
        for _, p in ipairs(old) do pcall(p.Destroy, p) end
    else
        -- partial build — destroy fragments, keep old pool
        for _, p in ipairs(nxt) do pcall(p.Destroy, p) end
    end
end

local function DestroyArcVis()
    local old = ArcPool; ArcPool = {}; lastArcColor = nil
    for _, p in ipairs(old) do pcall(p.Destroy, p) end
end

--[[
    SetBeam — PERF-E:
    • Skips the Size write when len+thick haven't changed by >0.005.
    • Avoids Vector3 midpoint allocation by passing all six scalars
      directly to CFrame.lookAt (which accepts two Vector3s, so we
      keep that call but inline the midpoint components to avoid a
      separate Vector3 allocation for the midpoint).
--]]
local function SetBeam(part, x1,y1,z1, x2,y2,z2, thick)
    local dx, dy, dz = x2-x1, y2-y1, z2-z1
    local len = math.sqrt(dx*dx + dy*dy + dz*dz)
    if len < 0.001 then
        part.Size = Vector3.new(0.001, 0.001, 0.001)
        return
    end
    -- PERF-E: skip Size write when values are stable
    local cache = _beamSzCache[part]
    if not cache or math.abs(len - cache[1]) > 0.005 or thick ~= cache[2] then
        part.Size = Vector3.new(thick, thick, len)
        if not cache then cache = {}; _beamSzCache[part] = cache end
        cache[1] = len; cache[2] = thick
    end
    local inv = 1 / len
    local mx, my, mz = (x1+x2)*0.5, (y1+y2)*0.5, (z1+z2)*0.5
    -- CFrame.lookAt still needs Vector3, but midpoint is inline (no separate alloc)
    part.CFrame = CFrame.lookAt(
        Vector3.new(mx, my, mz),
        Vector3.new(mx + dx*inv, my + dy*inv, mz + dz*inv)
    )
end

local function UpdateArcVis(baseCF, col)
    if not CFG.VisualizerEnabled then DestroyArcVis(); return end
    -- EDGE-1: guard against a partial pool
    if #ArcPool ~= ARC_TOTAL then BuildArcVis() end
    if #ArcPool ~= ARC_TOTAL then return end   -- build failed, skip frame
    if arcAngleDirty then RebuildArcAngles() end
    local reach    = CFG.Size
    local bx,by,bz = baseCF.Position.X,   baseCF.Position.Y,   baseCF.Position.Z
    local fx,fy,fz = baseCF.LookVector.X,  baseCF.LookVector.Y,  baseCF.LookVector.Z
    local rx,ry,rz = baseCF.RightVector.X, baseCF.RightVector.Y, baseCF.RightVector.Z
    for i = 1, ARC_SEGS+1 do
        local c, s = arcCosTable[i], arcSinTable[i]
        arcPtX[i]  = bx + (fx*c + rx*s) * reach
        arcPtY[i]  = by + (fy*c + ry*s) * reach
        arcPtZ[i]  = bz + (fz*c + rz*s) * reach
    end
    SetBeam(ArcPool[1], bx,by,bz, arcPtX[1],          arcPtY[1],          arcPtZ[1],          0.09)
    SetBeam(ArcPool[2], bx,by,bz, arcPtX[ARC_SEGS+1], arcPtY[ARC_SEGS+1], arcPtZ[ARC_SEGS+1], 0.09)
    for i = 1, ARC_SEGS do
        SetBeam(ArcPool[2+i],
            arcPtX[i],   arcPtY[i],   arcPtZ[i],
            arcPtX[i+1], arcPtY[i+1], arcPtZ[i+1], 0.07)
    end
    if col ~= lastArcColor then
        for i = 1, ARC_TOTAL do ArcPool[i].Color = col end
        lastArcColor = col
    end
end

