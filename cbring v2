-- An invisible Part in CoreGui adorned by a SelectionSphere.
-- Follows the tool Handle. Diameter = CFG.Size * 2.
--
-- Color states:
--   DISABLED  gray    — CFG.Enabled is false
--   CLEAR     green   — enabled, nobody in range
--   TARGET    yellow  — at least one victim in range
--   FIRING    red     — a drag coroutine is active

local VisPart   = nil
local VisSphere = nil

local COLOR = {
    DISABLED = Color3.fromRGB(115, 115, 128),
    CLEAR    = Color3.fromRGB(0,   210, 110),
    TARGET   = Color3.fromRGB(255, 195, 0  ),
    FIRING   = Color3.fromRGB(255, 30,  55 ),
}

-- Create or recreate the sphere visualizer part
local function BuildSphereVis()
    if VisPart then VisPart:Destroy() end
    
    local p = Instance.new("Part")
    p.Name = "_NCBSp"
    p.Anchored = false
    p.CanCollide = false
    p.Massless = true
    p.Transparency = 1
    p.Size = Vector3.new(1,1,1)
    p.Parent = game:GetService("CoreGui")
    
    local s = Instance.new("SelectionSphere")
    s.Adornee = p
    s.SurfaceTransparency = 0.85
    s.Transparency = 0.3
    s.Color3 = COLOR.CLEAR
    s.SurfaceColor3 = COLOR.CLEAR
    s.Parent = p
    
    VisPart = p
    VisSphere = s
end

-- Destroy the sphere visualizer
local function DestroySphereVis()
    if VisPart then
        VisPart:Destroy()
        VisPart = nil
        VisSphere = nil
    end
end

-- Update sphere position and appearance
local function UpdateSphereVis(handle, col)
    if not CFG.VisualizerEnabled then
        DestroySphereVis()
        return
    end
    
    if not VisPart or not VisPart.Parent then
        BuildSphereVis()
    end
    
    local d = CFG.Size * 2
    VisPart.Size = Vector3.new(d, d, d)
    VisPart.CFrame = handle.CFrame
    
    if VisSphere then
        VisSphere.Color3 = col
        VisSphere.SurfaceColor3 = col
    end
end

