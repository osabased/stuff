-- ── Slider Widget ─────────────────────────────────────────────────────────

local function MkSlider(parent, y, label, mn, mx, def, fmt, onChange)
    local row = MkFrame(parent, UDim2.new(1,0,0,UI.RowH),
        UDim2.new(0,0,0,y), Color3.fromRGB(0,0,0), 2)
    row.BackgroundTransparency = 1
    
    MkLabel(row, label, UDim2.new(0,95,1,0), UDim2.new(0,UI.Pad,0,0),
        UI.FontBody, UI.TextSz, UI.MUTED, 3)
    
    local track = MkFrame(row, UDim2.new(0,UI.SliderW,0,UI.SliderH),
        UDim2.new(0,108,0.5,-UI.SliderH/2), Color3.fromRGB(38,38,52), 3)
    MkCorner(track, 4)
    
    local fill = MkFrame(track, UDim2.new(0,0,1,0), UDim2.new(0,0,0,0), UI.ACCENT, 4)
    MkCorner(fill, 4)
    
    local KS = UI.KnobSz
    local knob = MkFrame(track, UDim2.new(0,KS,0,KS),
        UDim2.new(0,-KS/2,0.5,-KS/2), Color3.fromRGB(255,255,255), 5)
    MkCorner(knob, KS)
    MkStroke(knob, UI.ACCENT, 2)
    
    local valLbl = MkLabel(row, fmt(def), UDim2.new(0,58,1,0),
        UDim2.new(0,108+UI.SliderW+6,0,0), UI.Font, UI.TextSz, UI.ACCENT, 3)
    
    local current  = def
    local dragging = false
    
    local function SetVal(v)
        v = math.clamp(v, mn, mx)
        if math.floor(mn)==mn and math.floor(mx)==mx and math.floor(def)==def then
            v = math.round(v)
        else
            v = math.floor(v*100+0.5)/100
        end
        
        current = v
        local a = (v-mn)/(mx-mn)
        fill.Size = UDim2.new(a,0,1,0)
        knob.Position = UDim2.new(a,-KS/2,0.5,-KS/2)
        valLbl.Text = fmt(v)
        
        if onChange then onChange(v) end
    end
    
    SetVal(def)
    
    knob.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true
        end
    end)
    
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=false
        end
    end)
    
    UIS.InputChanged:Connect(function(i)
        if not dragging or i.UserInputType~=Enum.UserInputType.MouseMovement then return end
        local r = track.AbsoluteSize.X
        local x = math.clamp(i.Position.X - track.AbsolutePosition.X, 0, r)
        SetVal(mn + (x/r)*(mx-mn))
    end)
    
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging = true
            local r = track.AbsoluteSize.X
            local x = math.clamp(i.Position.X - track.AbsolutePosition.X, 0, r)
            SetVal(mn + (x/r)*(mx-mn))
        end
    end)
    
    return { SetVal=SetVal, GetVal=function() return current end }
end

