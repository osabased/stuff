--]]

local ScreenGui = nil

-- ── UI constants ────────────────────────────────────────────
local UI = {
    W            = 320,
    H            = 310,
    TitleH       = 32,
    RowH         = 34,
    Pad          = 12,
    SliderW      = 170,
    SliderH      = 8,
    KnobSz       = 16,
    Font         = Enum.Font.GothamBold,
    FontBody     = Enum.Font.Gotham,
    TextSz       = 13,
    TitleSz      = 14,
    BG           = Color3.fromRGB(15,  15,  20 ),
    PANEL        = Color3.fromRGB(22,  22,  30 ),
    ACCENT       = Color3.fromRGB(0,   200, 120),
    ACCENT2      = Color3.fromRGB(255, 60,  100),
    TEXT         = Color3.fromRGB(220, 220, 230),
    MUTED        = Color3.fromRGB(110, 110, 130),
    BORDER       = Color3.fromRGB(40,  40,  55 ),
}

-- ── Helper: make a Frame ─────────────────────────────────────
local function MkFrame(parent, size, pos, color, zindex)
    local f         = Instance.new("Frame")
    f.Size          = size
    f.Position      = pos
    f.BackgroundColor3 = color or UI.PANEL
    f.BorderSizePixel  = 0
    f.ZIndex        = zindex or 1
    f.Parent        = parent
    return f
end

-- ── Helper: make a Label ────────────────────────────────────
local function MkLabel(parent, text, size, pos, font, tsz, color, zindex, xalign)
    local l         = Instance.new("TextLabel")
    l.Size          = size
    l.Position      = pos
    l.Text          = text
    l.Font          = font or UI.FontBody
    l.TextSize      = tsz or UI.TextSz
    l.TextColor3    = color or UI.TEXT
    l.BackgroundTransparency = 1
    l.ZIndex        = zindex or 2
    l.TextXAlignment = xalign or Enum.TextXAlignment.Left
    l.Parent        = parent
    return l
end

-- ── Helper: make a rounded corner UICorner ──────────────────
local function MkCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
end

-- ── Helper: make a UIStroke ─────────────────────────────────
local function MkStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or UI.BORDER
    s.Thickness = thickness or 1
    s.Parent = parent
end

-- ── Slider builder ──────────────────────────────────────────
--[[
    Creates a labeled slider row.
    Parameters:
        parent    : Frame to attach to
        yOffset   : UDim2 Y position of the row
        label     : display name
        min/max   : value range
        default   : initial value
        fmt       : function(value) → string suffix  e.g. " studs"
        onChange  : function(value) called on every drag step
    Returns:
        { SetValue = fn, GetValue = fn, Label = TextLabel }
--]]
local function MkSlider(parent, yOffset, label, min, max, default, fmt, onChange)
    local ROW_H = UI.RowH
    local PAD   = UI.Pad

    -- Row container
    local row = MkFrame(parent,
        UDim2.new(1, 0, 0, ROW_H),
        UDim2.new(0, 0, 0, yOffset),
        Color3.fromRGB(0,0,0), 2)
    row.BackgroundTransparency = 1

    -- Left label
    MkLabel(row, label,
        UDim2.new(0, 95, 1, 0),
        UDim2.new(0, PAD, 0, 0),
        UI.FontBody, UI.TextSz, UI.MUTED, 3)

    -- Track background
    local trackBG = MkFrame(row,
        UDim2.new(0, UI.SliderW, 0, UI.SliderH),
        UDim2.new(0, 108, 0.5, -UI.SliderH/2),
        Color3.fromRGB(40, 40, 55), 3)
    MkCorner(trackBG, 4)

    -- Track fill (accent color, grows left → right)
    local trackFill = MkFrame(trackBG,
        UDim2.new(0, 0, 1, 0),
        UDim2.new(0, 0, 0, 0),
        UI.ACCENT, 4)
    MkCorner(trackFill, 4)

    -- Knob
    local KS = UI.KnobSz
    local knob = MkFrame(trackBG,
        UDim2.new(0, KS, 0, KS),
        UDim2.new(0, -KS/2, 0.5, -KS/2),
        Color3.fromRGB(255, 255, 255), 5)
    MkCorner(knob, KS)
    MkStroke(knob, UI.ACCENT, 2)

    -- Value label (right of slider)
    local valLabel = MkLabel(row,
        fmt(default),
        UDim2.new(0, 60, 1, 0),
        UDim2.new(0, 108 + UI.SliderW + 6, 0, 0),
        UI.Font, UI.TextSz, UI.ACCENT, 3)

    -- ── State ──────────────────────────────────────────────
    local current = default
    local dragging = false

    local function SetValue(val)
        val     = math.clamp(val, min, max)
        -- round to 2 dp for floats, integer for ints
        if math.floor(min) == min and math.floor(max) == max and math.floor(default) == default then
            val = math.round(val)
        else
            val = math.floor(val * 100 + 0.5) / 100
        end
        current = val

        local alpha = (val - min) / (max - min)
        trackFill.Size     = UDim2.new(alpha, 0, 1, 0)
        knob.Position      = UDim2.new(alpha, -KS/2, 0.5, -KS/2)
        valLabel.Text      = fmt(val)

        if onChange then onChange(val) end
    end

    local function GetValue() return current end

    -- Initialize position
    SetValue(default)

    -- ── Drag logic ─────────────────────────────────────────
    knob.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)

    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UIS.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local absPos  = trackBG.AbsolutePosition
        local absSize = trackBG.AbsoluteSize
        local relX    = math.clamp(inp.Position.X - absPos.X, 0, absSize.X)
        local alpha   = relX / absSize.X
        SetValue(min + alpha * (max - min))
    end)

    -- Also allow clicking anywhere on the track
    trackBG.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local absPos  = trackBG.AbsolutePosition
            local absSize = trackBG.AbsoluteSize
            local relX    = math.clamp(inp.Position.X - absPos.X, 0, absSize.X)
            SetValue(min + (relX / absSize.X) * (max - min))
        end
    end)

    return { SetValue = SetValue, GetValue = GetValue, Label = valLabel }
end

-- ── Toggle button builder ────────────────────────────────────
local function MkToggle(parent, xOffset, yOffset, label, default, onChange)
    local BTN_W, BTN_H = 46, 22

    local container = MkFrame(parent,
        UDim2.new(0, BTN_W + 8 + 70, 0, BTN_H + 4),
        UDim2.new(0, xOffset, 0, yOffset),
        Color3.fromRGB(0,0,0), 2)
    container.BackgroundTransparency = 1

    -- Pill track
    local track = MkFrame(container,
        UDim2.new(0, BTN_W, 0, BTN_H),
        UDim2.new(0, 0, 0, 2),
        Color3.fromRGB(50, 50, 65), 3)
    MkCorner(track, BTN_H)
    MkStroke(track, UI.BORDER, 1)

    -- Knob
    local KS = BTN_H - 6
    local knob = MkFrame(track,
        UDim2.new(0, KS, 0, KS),
        UDim2.new(0, 3, 0.5, -KS/2),
        Color3.fromRGB(180, 180, 200), 4)
    MkCorner(knob, KS)

    -- Label
    MkLabel(container, label,
        UDim2.new(0, 70, 1, 0),
        UDim2.new(0, BTN_W + 8, 0, 0),
        UI.FontBody, UI.TextSz, UI.TEXT, 3)

    -- ── State ──────────────────────────────────────────────
    local enabled = default

    local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad)

    local function SetState(state)
        enabled = state
        local targetX  = state and (BTN_W - KS - 3) or 3
        local trackCol = state and UI.ACCENT or Color3.fromRGB(50, 50, 65)
        local knobCol  = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(180,180,200)

        TweenService:Create(knob, tweenInfo,
            { Position = UDim2.new(0, targetX, 0.5, -KS/2),
              BackgroundColor3 = knobCol }):Play()
        TweenService:Create(track, tweenInfo,
            { BackgroundColor3 = trackCol }):Play()

        if onChange then onChange(state) end
    end

    SetState(default)

    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            SetState(not enabled)
        end
    end)

    return { SetState = SetState, GetState = function() return enabled end }
end

-- ── Stats strip updater (returns a function to refresh labels) ─
local function MkStatsStrip(parent, yOffset)
    local strip = MkFrame(parent,
        UDim2.new(1, 0, 0, 28),
        UDim2.new(0, 0, 0, yOffset),
        Color3.fromRGB(10, 10, 15), 2)
    MkStroke(strip, UI.BORDER, 1)

    local killLbl = MkLabel(strip, "Kills: 0",
        UDim2.new(0, 80, 1, 0),
        UDim2.new(0, UI.Pad, 0, 0),
        UI.Font, 12, UI.ACCENT, 3)

    local distLbl = MkLabel(strip, "AvgDist: —",
        UDim2.new(0, 90, 1, 0),
        UDim2.new(0, 95, 0, 0),
        UI.Font, 12, UI.TEXT, 3)

    local lastLbl = MkLabel(strip, "Last: —",
        UDim2.new(0, 110, 1, 0),
        UDim2.new(0, 195, 0, 0),
        UI.Font, 12, UI.MUTED, 3)

    return function()
        killLbl.Text = "Kills: " .. Stats.Kills
        local avg = Stats.Kills > 0
            and string.format("%.1f", Stats.TotalDist / Stats.Kills)
            or "—"
        distLbl.Text = "AvgDist: " .. avg
        lastLbl.Text = "Last: " .. Stats.LastVictim
    end
end

