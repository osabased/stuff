        UDim2.new(1, 0, 0, 8),
        UDim2.new(0, 0, 1, -8),
        Color3.fromRGB(20, 20, 28), 2)

    -- Accent left bar
    local accentBar = MkFrame(titleBar,
        UDim2.new(0, 3, 0, 18),
        UDim2.new(0, UI.Pad, 0.5, -9),
        UI.ACCENT, 3)
    MkCorner(accentBar, 2)

    MkLabel(titleBar, "NoCBring Config",
        UDim2.new(0, 180, 1, 0),
        UDim2.new(0, UI.Pad + 10, 0, 0),
        UI.Font, UI.TitleSz, UI.TEXT, 3)

    -- Close button
    local closeBtn = MkFrame(titleBar,
        UDim2.new(0, 24, 0, 24),
        UDim2.new(1, -32, 0.5, -12),
        Color3.fromRGB(60, 20, 30), 3)
    MkCorner(closeBtn, 4)
    MkLabel(closeBtn, "×", UDim2.new(1,0,1,0), UDim2.new(0,0,0,0),
        UI.Font, 16, UI.ACCENT2, 4, Enum.TextXAlignment.Center)

    closeBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            win.Visible = false
            shadow.Visible = false
            guiVisible = false
        end
    end)

    -- ── Drag logic for window ────────────────────────────────
    local draggingWin = false
    local dragStart, winStart

    titleBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWin = true
            dragStart   = inp.Position
            winStart    = win.Position
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWin = false
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if draggingWin and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = inp.Position - dragStart
            win.Position    = UDim2.new(
                winStart.X.Scale, winStart.X.Offset + delta.X,
                winStart.Y.Scale, winStart.Y.Offset + delta.Y)
            shadow.Position = UDim2.new(
                winStart.X.Scale, winStart.X.Offset + delta.X - 8,
                winStart.Y.Scale, winStart.Y.Offset + delta.Y - 8)
        end
    end)

    -- ── Content area ─────────────────────────────────────────
    local content = MkFrame(win,
        UDim2.new(1, 0, 1, -UI.TitleH),
        UDim2.new(0, 0, 0, UI.TitleH),
        UI.BG, 2)

    local y = 4  -- running Y offset inside content

    -- ── Sliders section header ───────────────────────────────
    MkLabel(content, "REACH & TIMING",
        UDim2.new(1, -UI.Pad*2, 0, 16),
        UDim2.new(0, UI.Pad, 0, y),
        UI.Font, 10, UI.MUTED, 3)
    y = y + 18

    -- Divider
    MkFrame(content,
        UDim2.new(1, -UI.Pad*2, 0, 1),
        UDim2.new(0, UI.Pad, 0, y),
        UI.BORDER, 3)
    y = y + 6

    -- SIZE slider  (5 – 30 studs)
    sliders.Size = MkSlider(content, y, "Size",
        5, 30, CFG.Size,
        function(v) return string.format("%.0f st", v) end,
        function(v)
            CFG.Size = v
            -- Live-update visualizer sphere size
            if VisPart then
                local s = v * 2
                VisPart.Size = Vector3.new(s, s, s)
            end
        end)
    y = y + UI.RowH

    -- LERP FRAMES slider  (2 – 12 frames)
    sliders.LerpFrames = MkSlider(content, y, "LerpFrames",
        2, 12, CFG.LerpFrames,
        function(v) return string.format("%.0f fr", v) end,
        function(v) CFG.LerpFrames = math.round(v) end)
    y = y + UI.RowH

    -- DRAG COOLDOWN slider  (0.10 – 1.50 s)
    sliders.DragCooldown = MkSlider(content, y, "Cooldown",
        0.10, 1.50, CFG.DragCooldown,
        function(v) return string.format("%.2f s", v) end,
        function(v) CFG.DragCooldown = v end)
    y = y + UI.RowH

    -- ANGLE CAP slider  (15 – 90 °)
    sliders.AngleCap = MkSlider(content, y, "AngleCap",
        15, 90, CFG.AngleCap,
        function(v) return string.format("%.0f °", v) end,
        function(v) CFG.AngleCap = v end)
    y = y + UI.RowH + 4

    -- ── Remote name textbox ──────────────────────────────────
    MkLabel(content, "RemoteName",
        UDim2.new(0, 95, 0, 20),
        UDim2.new(0, UI.Pad, 0, y),
        UI.FontBody, UI.TextSz, UI.MUTED, 3)

    local remoteBG = MkFrame(content,
        UDim2.new(0, UI.W - 116, 0, 22),
        UDim2.new(0, 108, 0, y + 1),
        Color3.fromRGB(30, 30, 42), 3)
    MkCorner(remoteBG, 4)
    MkStroke(remoteBG, UI.BORDER, 1)

    local remoteBox              = Instance.new("TextBox")
    remoteBox.Size               = UDim2.new(1, -8, 1, 0)
    remoteBox.Position           = UDim2.new(0, 4, 0, 0)
    remoteBox.Text               = CFG.RemoteName
    remoteBox.Font               = UI.FontBody
    remoteBox.TextSize           = UI.TextSz
    remoteBox.TextColor3         = UI.TEXT
    remoteBox.BackgroundTransparency = 1
    remoteBox.BorderSizePixel    = 0
    remoteBox.ZIndex             = 4
    remoteBox.PlaceholderText    = "e.g. DamageRemote"
    remoteBox.PlaceholderColor3  = UI.MUTED
    remoteBox.ClearTextOnFocus   = false
    remoteBox.Parent             = remoteBG

    remoteBox.FocusLost:Connect(function()
        if remoteBox.Text ~= "" then
            CFG.RemoteName  = remoteBox.Text
            currentRemote   = nil   -- force re-search
            Notify("Remote: " .. CFG.RemoteName)
        end
    end)

    y = y + 30

    -- ── Toggle row ───────────────────────────────────────────
    MkFrame(content,
        UDim2.new(1, -UI.Pad*2, 0, 1),
        UDim2.new(0, UI.Pad, 0, y),
        UI.BORDER, 3)
    y = y + 6

    toggles.Enabled = MkToggle(content, UI.Pad, y, "Enabled",
        CFG.Enabled, function(v) CFG.Enabled = v end)

    toggles.Visualizer = MkToggle(content, UI.W/2, y, "Visualizer",
        CFG.VisualizerEnabled, function(v)
            CFG.VisualizerEnabled = v
            if not v then DestroyVisualizer() end
        end)

    y = y + 30

    -- ── Stats strip ──────────────────────────────────────────
    MkFrame(content,
        UDim2.new(1, -UI.Pad*2, 0, 1),
        UDim2.new(0, UI.Pad, 0, y),
        UI.BORDER, 3)
    y = y + 4

    refreshStats = MkStatsStrip(content, y)
end

BuildGUI()

-- ═══════════════════════════════════════════════════════════════
--  SECTION 3 — CORE DRAG ROUTINE
-- ═══════════════════════════════════════════════════════════════
local function DragAndFire(victim, attackerRoot, remote)
    local uid  = victim.UserId
    local char = victim.Character
    if not char then return end

    local torso    = char:FindFirstChild("Torso")
    local humanoid = char:FindFirstChild("Humanoid")
    if not torso or not humanoid or humanoid.Health <= 0 then return end

    if ActiveDrags[uid] then return end
    if tick() - (LastDrag[uid] or 0) < CFG.DragCooldown then return end
    if not IsInFrontArc(attackerRoot, torso) then return end

    -- Record distance BEFORE drag (real server-side distance)
    local realDist = (attackerRoot.Position - torso.Position).Magnitude

    ActiveDrags[uid] = true
    LastDrag[uid]    = tick()
    Stats.ActiveDrags = Stats.ActiveDrags + 1

    coroutine.wrap(function()
        local destination = attackerRoot.CFrame * CFrame.new(1.2, 0, -2.8)

        -- Suppress signals (same-frame, no yield)
        SuppressSignal(torso.Changed)
        SuppressSignal(torso:GetPropertyChangedSignal("CFrame"))

        -- Velocity spoof
        local lerpPath   = destination.Position - torso.Position
        local spoofSpeed = math.clamp(lerpPath.Magnitude / (CFG.LerpFrames / 60), 0, 55)
        torso.AssemblyLinearVelocity = lerpPath.Unit * spoofSpeed

        -- EaseInQuad lerp over CFG.LerpFrames frames
        local origin = torso.CFrame
        for i = 1, CFG.LerpFrames do
            local alpha = (i / CFG.LerpFrames) ^ 2
            torso.CFrame = origin:Lerp(destination, alpha)
            RunService.Heartbeat:Wait()
        end

        -- Restore signals
        RestoreSignal(torso.Changed)
        RestoreSignal(torso:GetPropertyChangedSignal("CFrame"))

        -- Fire damage event
        if remote then
            pcall(function() remote:FireServer(victim) end)
        end

        -- Update session stats
        Stats.Kills       = Stats.Kills + 1
        Stats.TotalDist   = Stats.TotalDist + realDist
        Stats.LastVictim  = victim.Name

        Stats.ActiveDrags = math.max(0, Stats.ActiveDrags - 1)
        ActiveDrags[uid]  = nil
    end)()
end

-- ═══════════════════════════════════════════════════════════════
--  SECTION 4 — HEARTBEAT (scan + visualizer update)
-- ═══════════════════════════════════════════════════════════════
Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    -- Refresh stats strip every frame (cheap label writes)
    if refreshStats then refreshStats() end

    if CFG.ScriptKilled then return end

    local char = LocalPlayer.Character
    if not char then return end

    local tool     = char:FindFirstChildOfClass("Tool")
    local humanoid = char:FindFirstChild("Humanoid")
    local root     = char:FindFirstChild("HumanoidRootPart")

    if not tool or not humanoid or not root then
        currentRemote = nil
        DestroyVisualizer()
        return
    end

    local handle = tool:FindFirstChild("Handle")
    if not handle then
        DestroyVisualizer()
        return
    end

    -- Cache remote reference
    if not currentRemote then
        currentRemote = FindRemote(tool)
    end

    -- ── Count targets in range (for visualizer color) ───────
    local targetsInRange = 0
    local mouseDown = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local pchar = player.Character
        if not pchar then continue end
        local pTorso = pchar:FindFirstChild("Torso")
        if not pTorso then continue end

        local dist = (handle.Position - pTorso.Position).Magnitude
        if dist <= CFG.Size then
            targetsInRange = targetsInRange + 1
            -- Only drag on mouse-down
            if CFG.Enabled and mouseDown then
                DragAndFire(player, root, currentRemote)
            end
        end
    end

    -- ── Update visualizer ────────────────────────────────────
    UpdateVisualizer(handle, targetsInRange, Stats.ActiveDrags)
end)

-- ═══════════════════════════════════════════════════════════════
--  SECTION 5 — KEYBINDS
-- ═══════════════════════════════════════════════════════════════
Connections.Input = UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if input.KeyCode == CFG.Keybinds.Toggle then
        CFG.Enabled = not CFG.Enabled
        if toggles.Enabled then toggles.Enabled.SetState(CFG.Enabled) end
        Notify("Enabled: " .. tostring(CFG.Enabled))

    elseif input.KeyCode == CFG.Keybinds.ToggleVis then
        CFG.VisualizerEnabled = not CFG.VisualizerEnabled
        if toggles.Visualizer then toggles.Visualizer.SetState(CFG.VisualizerEnabled) end
        if not CFG.VisualizerEnabled then DestroyVisualizer() end
        Notify("Visualizer: " .. tostring(CFG.VisualizerEnabled))

    elseif input.KeyCode == CFG.Keybinds.ToggleUI then
        guiVisible = not guiVisible
        if ScreenGui then
            for _, obj in ipairs(ScreenGui:GetChildren()) do
                obj.Visible = guiVisible
            end
        end

    elseif input.KeyCode == CFG.Keybinds.KillScript then
        CFG.ScriptKilled = true
        DestroyVisualizer()
        if ScreenGui then ScreenGui:Destroy() end
        for _, c in pairs(Connections) do pcall(function() c:Disconnect() end) end
        Notify("Script killed.")
    end
end)

-- ─────────────────────────────────────────────────────────────
-- CHARACTER WIRING (clear remote cache on tool swap)
-- ─────────────────────────────────────────────────────────────
local function OnCharacter(char)
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then currentRemote = nil end
    end)
    char.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") then currentRemote = nil end
    end)
end

if LocalPlayer.Character then OnCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(OnCharacter)

Notify("NoCBring v2 loaded. Size=" .. CFG.Size .. "  [C] toggle UI")

