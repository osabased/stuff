local function Notify(text)
    StarterGui:SetCore("SendNotification", {
        Title = "NoCBring",
        Text  = text,
        Duration = 2,
    })
end

local function SuppressSignal(signal)
    for _, c in ipairs(getconnections(signal)) do
        pcall(function() c:Disable() end)
    end
end

local function RestoreSignal(signal)
    for _, c in ipairs(getconnections(signal)) do
        pcall(function() c:Enable() end)
    end
end

local function IsInFrontArc(attackerRoot, victimTorso)
    local toVictim = (victimTorso.Position - attackerRoot.Position)
    if toVictim.Magnitude < 0.1 then return false end
    local dot   = attackerRoot.CFrame.LookVector:Dot(toVictim.Unit)
    local angle = math.deg(math.acos(math.clamp(dot, -1, 1)))
    return angle <= CFG.AngleCap
end

local function FindRemote(tool)
    local r = tool:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then return r end
    r = ReplicatedStorage:FindFirstChild(CFG.RemoteName, true)
    if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then return r end
    return nil
end

