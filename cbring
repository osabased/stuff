        UDim2.new(1, 0, 0, UI.TitleH),
        UDim2.new(0, 0, 0, 0),
        Color3.fromRGB(20, 20, 28), 2)
    MkCorner(titleBar, 8)

    -- Bottom square fill for titleBar (to hide bottom-radius)
