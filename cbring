if getgenv().GLOBALENABLED == true then return end

getgenv().GLOBALENABLED = true

getgenv().Settings = {
    ScriptKilled = false,
    Enabled = true,
    VisualizerEnabled = false,
    Size = 10,
    Increment = 1,
    Keybinds = {
        Increase = Enum.KeyCode.J,
        Decrease = Enum.KeyCode.K,
        Toggle = Enum.KeyCode.Z,
        VisualizerToggle = Enum.KeyCode.X,
        KillScript = Enum.KeyCode.P
    }
}

local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local Players = game:GetService("Players")

local Connections = {}
local Instances = {}

local LocalPlayer = Players.LocalPlayer

local function Notify(Text)
    StarterGui:SetCore("SendNotification", {
        Title = "Summer Cbring",
        Text = Text,
    })
end

Notify("Loaded.")

Connections.InputBegan = UIS.InputBegan:Connect(function(Input, GPE)
    local Success, Error = pcall(function()
        if GPE then return end
        
        if Input.KeyCode == getgenv().Settings.Keybinds.Increase then
            getgenv().Settings.Size = getgenv().Settings.Size + getgenv().Settings.Increment
            Notify("Size is " .. getgenv().Settings.Size)
        elseif Input.KeyCode == getgenv().Settings.Keybinds.Decrease then
            getgenv().Settings.Size = getgenv().Settings.Size - getgenv().Settings.Increment
            Notify("Size is " .. getgenv().Settings.Size)
        elseif Input.KeyCode == getgenv().Settings.Keybinds.Toggle then
            getgenv().Settings.Enabled = not getgenv().Settings.Enabled
            Notify("Enabled: " .. tostring(getgenv().Settings.Enabled))
        elseif Input.KeyCode == getgenv().Settings.Keybinds.VisualizerToggle then
            getgenv().Settings.VisualizerEnabled = not getgenv().Settings.VisualizerEnabled
            Notify("Visualizer: " .. tostring(getgenv().Settings.VisualizerEnabled))
        elseif Input.KeyCode == getgenv().Settings.Keybinds.KillScript then
            getgenv().Settings.ScriptKilled = true
            Notify("Killed script.")
            for i, v in pairs(Connections) do
                pcall(function() v:Disconnect() end)
            end
            for j, k in pairs(Instances) do
                k:Destroy()
            end
        end
    end)
    
    if Error then
        warn(Error)
    end
end)

local function DisableConnections(Connection)
    for i, v in pairs(getconnections(Connection)) do
		pcall(function()
			v:Disable()
		end)
	end
end

local function EnableConnections(Connection)
    for i, v in pairs(getconnections(Connection)) do
		pcall(function()
			v:Enable()
		end)
	end
end

