--  SECTION 1 — VISUAL REACH INDICATOR
-- ═══════════════════════════════════════════════════════════════
--[[
    The visualizer consists of:
      • A massless, unanchored Part parented to CoreGui
        (keeps it off the workspace hierarchy, avoids game-side cleanup)
      • A SelectionSphere adorning that Part
      • Every Heartbeat: Part.CFrame = Handle.CFrame, Part.Size = radius sphere

    Color states:
      GRAY   (#888)  disabled
      GREEN  (#00FF88) enabled, no targets in range
      YELLOW (#FFD700) target(s) in range, about to fire
      RED    (#FF2040) drag actively running
--]]

local VisPart   = nil   -- the invisible Part
local VisSphere = nil   -- the SelectionSphere

local COLOR = {
    DISABLED = Color3.fromRGB(130, 130, 130),
    CLEAR    = Color3.fromRGB(0,   220, 120),
    TARGET   = Color3.fromRGB(255, 200, 0  ),
    FIRING   = Color3.fromRGB(255, 30,  60 ),
}

local function BuildVisualizer()
    if VisPart then VisPart:Destroy() end

    local part        = Instance.new("Part")
    part.Name         = "_NCBVis"
    part.Anchored     = false
    part.CanCollide   = false
    part.Massless     = true
    part.Transparency = 1
    part.Size         = Vector3.new(1, 1, 1)
    part.Parent       = game:GetService("CoreGui")

    local sphere               = Instance.new("SelectionSphere")
    sphere.Name                = "_NCBSphere"
    sphere.Adornee             = part
    sphere.SurfaceTransparency = 0.85
    sphere.Transparency        = 0.3
    sphere.Color3              = COLOR.CLEAR
    sphere.SurfaceColor3       = COLOR.CLEAR
    sphere.Parent              = part

    VisPart   = part
    VisSphere = sphere
end

local function DestroyVisualizer()
    if VisPart then
        VisPart:Destroy()
        VisPart   = nil
        VisSphere = nil
    end
end

-- Called every Heartbeat with current handle + targets-in-range count
local function UpdateVisualizer(handle, targetsInRange, activeDragCount)
    if not CFG.VisualizerEnabled then
        DestroyVisualizer()
        return
    end

    if not VisPart or not VisPart.Parent then
        BuildVisualizer()
    end

    -- Sync size to current CFG.Size
    local s = CFG.Size * 2   -- diameter
    VisPart.Size   = Vector3.new(s, s, s)
    VisPart.CFrame = handle.CFrame

    -- Color logic
    local col
    if not CFG.Enabled then
        col = COLOR.DISABLED
    elseif activeDragCount > 0 then
        col = COLOR.FIRING
    elseif targetsInRange > 0 then
        col = COLOR.TARGET
    else
        col = COLOR.CLEAR
    end

    if VisSphere then
        VisSphere.Color3        = col
        VisSphere.SurfaceColor3 = col
    end
end

