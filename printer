
-- ============================================================
--  AC Recon — Human-Readable Report Printer
--  Run this AFTER ac_recon_v1.lua has completed.
--  Reads getgenv().__ac_recon and prints a structured,
--  plain-English report with remediation advice.
-- ============================================================

local report = getgenv().__ac_recon
if not report then
    warn("No report found. Run ac_recon_v1.lua first, then run this printer.")
    return
end

-- ── Helpers ──────────────────────────────────────────────────────────────────

local function lookup(section, key)
    for _, e in ipairs(report.entries) do
        if e.section == section and e.key == key then
            return e.value, e.severity
        end
    end
    return nil, nil
end

local function find_all(section_pattern, key_pattern)
    local results = {}
    for _, e in ipairs(report.entries) do
        local sec_match = (not section_pattern) or e.section:find(section_pattern, 1, true)
        local key_match = (not key_pattern)     or e.key:find(key_pattern,     1, true)
        if sec_match and key_match then
            table.insert(results, e)
        end
    end
    return results
end

local SEP_MAJOR = "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
local SEP_MINOR = "────────────────────────────────────────────────────────────────"

local function header(title)
    print("\n" .. SEP_MAJOR)
    print("  " .. title)
    print(SEP_MAJOR)
end

local function subheader(title)
    print("\n  " .. title)
    print("  " .. SEP_MINOR:sub(1, #title + 2))
end

local function finding(icon, label, detail, fix)
    print(string.format("\n  %s  %s", icon, label))
    if detail then
        for line in (detail .. "\n"):gmatch("([^\n]*)\n") do
            if line ~= "" then print("      " .. line) end
        end
    end
    if fix then
        print("      ╔ FIX ▶")
        for line in (fix .. "\n"):gmatch("([^\n]*)\n") do
            if line ~= "" then print("      ║  " .. line) end
        end
        print("      ╚")
    end
end

local function stat(label, value)
    print(string.format("      %-38s %s", label .. ":", tostring(value)))
end

