-- 1. Slimmed JSON Serializer with String Truncation
local function to_json(val, depth)
    depth = depth or 0
    local t = type(val)
    if t == "string" then
        -- TRUNCATE individual strings to 100 chars to prevent massive bloat
        local clean = val:gsub('\\','\\\\'):gsub('"','\\"'):gsub('\n',' '):gsub('\r',' ')
        if #clean > 100 then
            clean = clean:sub(1, 100) .. "..."
        end
        return '"' .. clean .. '"'
    elseif t == "boolean" or t == "number" then
        return tostring(val)
    elseif t == "table" then
        if depth > 6 then return '"[Depth Limit]"' end
        local is_array = true
        local n = 0
        for k in pairs(val) do
            n = n + 1
            if type(k) ~= "number" then is_array = false break end
        end
        if is_array then
            local parts = {}
            for _, v in ipairs(val) do table.insert(parts, to_json(v, depth+1)) end
            return "[" .. table.concat(parts, ",") .. "]"
        else
            local parts = {}
            for k, v in pairs(val) do
                table.insert(parts, '"' .. tostring(k) .. '":' .. to_json(v, depth+1))
            end
            return "{" .. table.concat(parts, ",") .. "}"
        end
    end
    return "null"
end

